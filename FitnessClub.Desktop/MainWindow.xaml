<Window x:Class="FitnessClub.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GymCRM" Height="780" Width="1280"
        MinHeight="620" MinWidth="1060"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentPrimary"   Color="#6366F1"/>
        <SolidColorBrush x:Key="AccentSecondary" Color="#8B5CF6"/>
        <SolidColorBrush x:Key="AccentPink"      Color="#EC4899"/>
        <SolidColorBrush x:Key="BgDeep"          Color="#030712"/>
        <SolidColorBrush x:Key="BgBase"          Color="#0A0F1A"/>
        <SolidColorBrush x:Key="TxtPrimary"      Color="#F9FAFB"/>
        <SolidColorBrush x:Key="TxtSecondary"    Color="#9CA3AF"/>
        <SolidColorBrush x:Key="TxtMuted"        Color="#4B5563"/>
        <SolidColorBrush x:Key="Success"         Color="#10B981"/>
        <SolidColorBrush x:Key="Warning"         Color="#F59E0B"/>
        <SolidColorBrush x:Key="Danger"          Color="#EF4444"/>

        <!-- NAV ICON BUTTON idle -->
        <Style x:Key="NavIconButton" TargetType="Button">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="Width"                      Value="44"/>
            <Setter Property="Height"                     Value="44"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="BgLayer" CornerRadius="14" Background="Transparent" Width="44" Height="44"/>
                            <ContentPresenter x:Name="IconPresenter"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              RenderTransformOrigin="0.5,0.5">
                                <ContentPresenter.RenderTransform>
                                    <ScaleTransform x:Name="IconScale" ScaleX="1" ScaleY="1"/>
                                </ContentPresenter.RenderTransform>
                            </ContentPresenter>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgLayer" Property="Background" Value="#6366F118"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleX" To="1.25" Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <BackEase EasingMode="EaseOut" Amplitude="0.4"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleY" To="1.25" Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <BackEase EasingMode="EaseOut" Amplitude="0.4"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="IconScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- NAV ICON BUTTON active -->
        <Style x:Key="NavIconButtonActive" TargetType="Button" BasedOn="{StaticResource NavIconButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid RenderTransformOrigin="0.5,0.5">
                            <Border Width="44" Height="44" CornerRadius="14" Margin="4,0,0,0" Opacity="0.85">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#6366F1" Offset="0"/>
                                        <GradientStop Color="#8B5CF6" Offset="0.6"/>
                                        <GradientStop Color="#EC4899" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#6366F1" BlurRadius="22" ShadowDepth="0" Opacity="0.55"/>
                                </Border.Effect>
                            </Border>
                            <Border x:Name="WhiteCard" Width="44" Height="44" CornerRadius="14"
                                    Background="#FFFFFF" Margin="6,0,0,0" RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="CardSlide" X="0"/>
                                </Border.RenderTransform>
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="4" Direction="270" Opacity="0.35"/>
                                </Border.Effect>
                            </Border>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="CardSlide" Storyboard.TargetProperty="X" To="3" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="CardSlide" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TitleBar buttons -->
        <Style x:Key="TitleBarIconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#4B5563"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" CornerRadius="10" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1F293780"/>
                                <Setter Property="Foreground" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WinCtrl" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#4B5563"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8" Margin="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1F2937"/>
                                <Setter Property="Foreground" Value="#6366F1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WinClose" TargetType="Button" BasedOn="{StaticResource WinCtrl}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8,14,8,8" Margin="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#7F1D1D"/>
                                <Setter Property="Foreground" Value="#FCA5A5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogoutTitleBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#4B5563"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" CornerRadius="9" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#7F1D1D40"/>
                                <Setter Property="Foreground" Value="#EF4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NotifItem" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#1F2937"/>
        </Style>
    </Window.Resources>

    <Border>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="80" ShadowDepth="0" Opacity="0.85"/>
        </Border.Effect>
        <Border CornerRadius="20" ClipToBounds="True" Background="#030712">
            <Border CornerRadius="20" BorderThickness="1">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1F2937" Offset="0"/>
                        <GradientStop Color="#6366F125" Offset="0.4"/>
                        <GradientStop Color="#111827" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="72"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- SIDEBAR -->
                    <Grid Grid.Column="0" ClipToBounds="True">
                        <Border>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#0D0B1E" Offset="0"/>
                                    <GradientStop Color="#100E22" Offset="0.5"/>
                                    <GradientStop Color="#0D0B1E" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <Border HorizontalAlignment="Right" Width="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#00000000" Offset="0"/>
                                    <GradientStop Color="#6366F120" Offset="0.3"/>
                                    <GradientStop Color="#6366F130" Offset="0.7"/>
                                    <GradientStop Color="#00000000" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="72"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- LOGO -->
                            <Border Grid.Row="0" Width="40" Height="40" CornerRadius="12"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#6366F1" Offset="0"/>
                                        <GradientStop Color="#8B5CF6" Offset="0.5"/>
                                        <GradientStop Color="#EC4899" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#6366F1" BlurRadius="16" ShadowDepth="0" Opacity="0.4"/>
                                </Border.Effect>
                                <TextBlock Text="G" Foreground="#FFFFFF"
                                           FontFamily="Segoe UI Variable, Segoe UI"
                                           FontSize="18" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <!-- NAV -->
                            <StackPanel Grid.Row="1" HorizontalAlignment="Center"
                                        VerticalAlignment="Top" Margin="0,8,0,0">

                                <!-- Dashboard -->
                                <Button x:Name="BtnDashboard" Style="{StaticResource NavIconButtonActive}"
                                        ToolTip="Дашборд" Margin="0,0,0,6"
                                        Click="Navigate_Click" Tag="Dashboard">
                                    <Path Data="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"
                                          Width="20" Height="20" Stretch="Uniform" Fill="#6366F1"/>
                                </Button>

                                <!-- Clients -->
                                <Button x:Name="BtnClients" Style="{StaticResource NavIconButton}"
                                        ToolTip="Клієнти" Margin="0,0,0,6"
                                        Click="Navigate_Click" Tag="Clients">
                                    <Path Data="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"
                                          Width="20" Height="20" Stretch="Uniform" Fill="#9CA3AF"/>
                                </Button>

                                <!-- Memberships -->
                                <Button x:Name="BtnMemberships" Style="{StaticResource NavIconButton}"
                                        ToolTip="Абонементи" Margin="0,0,0,6"
                                        Click="Navigate_Click" Tag="Memberships">
                                    <Path Data="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z"
                                          Width="20" Height="20" Stretch="Uniform" Fill="#9CA3AF"/>
                                </Button>

                                <!-- Schedule -->
                                <Button x:Name="BtnSchedule" Style="{StaticResource NavIconButton}"
                                        ToolTip="Розклад" Margin="0,0,0,6"
                                        Click="Navigate_Click" Tag="Schedule">
                                    <Path Data="M19 3h-1V1h-2v2H8V1H6v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z"
                                          Width="20" Height="20" Stretch="Uniform" Fill="#9CA3AF"/>
                                </Button>

                                <!-- Payments -->
                                <Button x:Name="BtnPayments" Style="{StaticResource NavIconButton}"
                                        ToolTip="Платежі" Margin="0,0,0,6"
                                        Click="Navigate_Click" Tag="Payments">
                                    <Path Data="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"
                                          Width="20" Height="20" Stretch="Uniform" Fill="#9CA3AF"/>
                                </Button>

                                <!-- Trainers -->
                                <Button x:Name="BtnTrainers" Style="{StaticResource NavIconButton}"
                                        ToolTip="Тренери" Margin="0,0,0,6"
                                        Click="Navigate_Click" Tag="Trainers">
                                    <Path Data="M13.49 5.48c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm-3.6 13.9l1-4.4 2.1 2v6h2v-7.5l-2.1-2 .6-3c1.3 1.5 3.3 2.5 5.5 2.5v-2c-1.9 0-3.5-1-4.3-2.4l-1-1.6c-.4-.6-1-1-1.7-1-.3 0-.5.1-.8.1l-5.2 2.2v4.7h2v-3.4l1.8-.7-1.6 8.1-4.9-1-.4 2 7 1.4z"
                                          Width="20" Height="20" Stretch="Uniform" Fill="#9CA3AF"/>
                                </Button>

                                <!-- Analytics -->
                                <Button x:Name="BtnAnalytics" Style="{StaticResource NavIconButton}"
                                        ToolTip="Аналітика" Margin="0,0,0,6"
                                        Click="Navigate_Click" Tag="Analytics">
                                    <Path Data="M5 9.2h3V19H5zM10.6 5h2.8v14h-2.8zm5.6 8H19v6h-2.8z"
                                          Width="20" Height="20" Stretch="Uniform" Fill="#9CA3AF"/>
                                </Button>

                                <!-- Роздільник -->
                                <Border Height="1" Width="28" Margin="0,4,0,4"
                                        Background="#1F2937" HorizontalAlignment="Center"/>

                                <!-- ══ МОНІТОРИНГ ДОСТУПУ (НОВИЙ) ══ -->
                                <Button x:Name="BtnMonitor" Style="{StaticResource NavIconButton}"
                                        ToolTip="Моніторинг входу" Margin="0,0,0,6"
                                        Click="Navigate_Click" Tag="Monitor">
                                    <Path Data="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 4l5 2.18V11c0 3.5-2.33 6.79-5 7.93C9.33 17.79 7 14.5 7 11V7.18L12 5z"
                                          Width="20" Height="20" Stretch="Uniform" Fill="#9CA3AF"/>
                                </Button>

                                <!-- Роздільник -->
                                <Border Height="1" Width="28" Margin="0,4,0,10"
                                        Background="#1F2937" HorizontalAlignment="Center"/>

                                <!-- Users (admin) -->
                                <StackPanel x:Name="AdminSection">
                                    <Button x:Name="BtnUsers" Style="{StaticResource NavIconButton}"
                                            ToolTip="Користувачі" Margin="0,0,0,6"
                                            Click="Navigate_Click" Tag="Users">
                                        <Path Data="M16.5 13c-1.2 0-3.07.34-4.5 1-1.43-.67-3.3-1-4.5-1C5.33 13 1 14.08 1 16.25V19h22v-2.75c0-2.17-4.33-3.25-6.5-3.25zm-4 4.5h-10v-1.25c0-.54 2.56-1.75 5-1.75s5 1.21 5 1.75v1.25zm9 0H14v-1.25c0-.46-.2-.86-.52-1.22.88-.3 1.96-.53 3.02-.53 2.44 0 5 1.21 5 1.75v1.25zM7.5 12c1.93 0 3.5-1.57 3.5-3.5S9.43 5 7.5 5 4 6.57 4 8.5 5.57 12 7.5 12zm0-5.5c1.1 0 2 .9 2 2s-.9 2-2 2-2-.9-2-2 .9-2 2-2zm9 5.5c1.93 0 3.5-1.57 3.5-3.5S18.43 5 16.5 5 13 6.57 13 8.5s1.57 3.5 3.5 3.5zm0-5.5c1.1 0 2 .9 2 2s-.9 2-2 2-2-.9-2-2 .9-2 2-2z"
                                              Width="20" Height="20" Stretch="Uniform" Fill="#9CA3AF"/>
                                    </Button>
                                    <Button x:Name="BtnBot" Style="{StaticResource NavIconButton}"
        ToolTip="Бот" Margin="0,0,0,6"
        Click="Navigate_Click" Tag="Bot">

                                        <Path Data="M12 2a2 2 0 00-2 2v1H8a4 4 0 00-4 4v5a4 4 0 004 4h1v2h2v-2h2v2h2v-2h1a4 4 0 004-4V9a4 4 0 00-4-4h-2V4a2 2 0 00-2-2zm-4 9a1 1 0 110-2 1 1 0 010 2zm8 0a1 1 0 110-2 1 1 0 010 2z"
          Width="20" Height="20"
          Stretch="Uniform"
          Fill="#9CA3AF"/>
                                    </Button>

                                </StackPanel>
                            </StackPanel>

                            <Border Grid.Row="2" Height="16"/>
                        </Grid>
                    </Grid>

                    <!-- MAIN AREA -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="52"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- TITLEBAR -->
                        <Grid Grid.Row="0" MouseDown="TitleBar_MouseDown">
                            <Border Background="#030712"/>
                            <Border VerticalAlignment="Bottom" Height="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#1F2937" Offset="0"/>
                                        <GradientStop Color="#6366F125" Offset="0.5"/>
                                        <GradientStop Color="#1F2937" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <Grid Margin="16,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border CornerRadius="6" Padding="10,4" Background="#1F293730">
                                        <TextBlock Foreground="#4B5563"
                                                   FontFamily="Segoe UI Variable, Segoe UI"
                                                   FontSize="10" FontWeight="SemiBold">
                                            <Run Text="GYMCRM"/>
                                            <Run Text="·" Foreground="#374151"/>
                                            <Run Text="v2.0" Foreground="#6366F1"/>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal"
                                            VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <Grid Margin="0,0,4,0">
                                        <Button x:Name="BtnNotifications"
                                                Style="{StaticResource TitleBarIconBtn}"
                                                ToolTip="Сповіщення" Click="Notifications_Click">
                                            <Path Data="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.9 2 2 2zm6-6v-5c0-3.07-1.64-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.63 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z"
                                                  Width="18" Height="18" Stretch="Uniform" Fill="#4B5563"/>
                                        </Button>
                                        <Popup x:Name="NotificationPopup"
                                               PlacementTarget="{Binding ElementName=BtnNotifications}"
                                               Placement="Bottom" HorizontalOffset="-264" VerticalOffset="6"
                                               StaysOpen="False" AllowsTransparency="True" PopupAnimation="Slide">
                                            <Border Width="300" CornerRadius="16" Background="#0D0B1E" BorderThickness="1">
                                                <Border.BorderBrush>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#6366F140" Offset="0"/>
                                                        <GradientStop Color="#1F2937" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.BorderBrush>
                                                <Border.Effect>
                                                    <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="8" Direction="270" Opacity="0.7"/>
                                                </Border.Effect>
                                                <Grid>
                                                    <Border CornerRadius="16,16,0,0" Padding="16,14" VerticalAlignment="Top">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                <GradientStop Color="#1F293740" Offset="0"/>
                                                                <GradientStop Color="#6366F115" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <Grid>
                                                            <TextBlock Text="Сповіщення" Foreground="#F9FAFB"
                                                                       FontFamily="Segoe UI Variable, Segoe UI"
                                                                       FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                            <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                                                    CornerRadius="6" Padding="8,3" Background="#6366F120">
                                                                <TextBlock Text="Немає нових" Foreground="#6366F1"
                                                                           FontFamily="Segoe UI Variable, Segoe UI" FontSize="10"/>
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                    <StackPanel Margin="0,48,0,0">
                                                        <Border Padding="16,28">
                                                            <StackPanel HorizontalAlignment="Center">
                                                                <Path Data="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.9 2 2 2zm6-6v-5c0-3.07-1.64-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.63 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z"
                                                                      Width="32" Height="32" Stretch="Uniform" Fill="#1F2937"
                                                                      HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                                                <TextBlock Text="Поки що порожньо" Foreground="#374151"
                                                                           FontFamily="Segoe UI Variable, Segoe UI"
                                                                           FontSize="12" HorizontalAlignment="Center"/>
                                                                <TextBlock Text="Тут з'являться ваші сповіщення" Foreground="#1F2937"
                                                                           FontFamily="Segoe UI Variable, Segoe UI"
                                                                           FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </Popup>
                                    </Grid>

                                    <Border Width="1" Height="20" Margin="4,0,8,0"
                                            Background="#1F2937" VerticalAlignment="Center"/>

                                    <!-- Profile chip -->
                                    <Border CornerRadius="10" Padding="6,4,10,4" Background="#1F293740"
                                            BorderThickness="1" Margin="0,0,6,0" VerticalAlignment="Center">
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="#374151" Opacity="0.3"/>
                                        </Border.BorderBrush>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="26" Height="26" CornerRadius="8"
                                                    VerticalAlignment="Center" Margin="0,0,8,0" BorderThickness="1">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#6366F130" Offset="0"/>
                                                        <GradientStop Color="#8B5CF620" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Border.BorderBrush>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#6366F150" Offset="0"/>
                                                        <GradientStop Color="#8B5CF640" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.BorderBrush>
                                                <TextBlock x:Name="AvatarText"
                                                           FontFamily="Segoe UI Variable, Segoe UI"
                                                           FontSize="11" FontWeight="Bold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock.Foreground>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#6366F1" Offset="0"/>
                                                            <GradientStop Color="#8B5CF6" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </TextBlock.Foreground>
                                                </TextBlock>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock x:Name="UserNameText" Foreground="#E5E7EB"
                                                           FontFamily="Segoe UI Variable, Segoe UI"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           MaxWidth="120" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock x:Name="UserRoleText" Foreground="#6B7280"
                                                           FontFamily="Segoe UI Variable, Segoe UI" FontSize="9"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Button Style="{StaticResource LogoutTitleBtn}" ToolTip="Вийти"
                                            Margin="0,0,6,0" Click="Logout_Click">
                                        <Path Data="M10.09 15.59L11.5 17l5-5-5-5-1.41 1.41L12.67 11H3v2h9.67l-2.58 2.59zM19 3H5c-1.11 0-2 .9-2 2v4h2V5h14v14H5v-4H3v4c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z"
                                              Width="16" Height="16" Stretch="Uniform" Fill="#4B5563"/>
                                    </Button>

                                    <Border Width="1" Height="20" Margin="2,0,4,0"
                                            Background="#1F2937" VerticalAlignment="Center"/>

                                    <Button Style="{StaticResource WinCtrl}" Click="Minimize_Click">
                                        <TextBlock Text="─" FontSize="12" FontWeight="Bold"/>
                                    </Button>
                                    <Button Style="{StaticResource WinCtrl}" x:Name="MaximizeBtn" Click="Maximize_Click">
                                        <TextBlock Text="□" FontSize="10"/>
                                    </Button>
                                    <Button Style="{StaticResource WinClose}" Click="Close_Click">
                                        <TextBlock Text="✕" FontSize="11" FontWeight="SemiBold"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <!-- CONTENT -->
                        <Grid Grid.Row="1" Background="#030712">
                            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" Background="Transparent"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Border>
</Window>
