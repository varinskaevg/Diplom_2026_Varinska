<Window x:Class="FitnessClub.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GymCRM" Height="560" Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>

        <!-- Стиль TextBox -->
        <Style x:Key="LoginField" TargetType="TextBox">
            <Setter Property="Height"              Value="46"/>
            <Setter Property="Background"          Value="#0E1128"/>
            <Setter Property="Foreground"          Value="#D8D4F8"/>
            <Setter Property="CaretBrush"          Value="#A78BFA"/>
            <Setter Property="SelectionBrush"      Value="#6C63FF"/>
            <Setter Property="BorderThickness"     Value="0"/>
            <Setter Property="FontFamily"          Value="Segoe UI"/>
            <Setter Property="FontSize"            Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#1A1F3A"
                                BorderThickness="1"
                                CornerRadius="11">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="16,0"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bg" Property="BorderBrush" Value="#6C63FF"/>
                                <Setter TargetName="bg" Property="Background"  Value="#111430"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль PasswordBox -->
        <Style x:Key="LoginPass" TargetType="PasswordBox">
            <Setter Property="Height"              Value="46"/>
            <Setter Property="Background"          Value="#0E1128"/>
            <Setter Property="Foreground"          Value="#D8D4F8"/>
            <Setter Property="CaretBrush"          Value="#A78BFA"/>
            <Setter Property="SelectionBrush"      Value="#6C63FF"/>
            <Setter Property="BorderThickness"     Value="0"/>
            <Setter Property="FontFamily"          Value="Segoe UI"/>
            <Setter Property="FontSize"            Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#1A1F3A"
                                BorderThickness="1"
                                CornerRadius="11">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="16,0"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bg" Property="BorderBrush" Value="#6C63FF"/>
                                <Setter TargetName="bg" Property="Background"  Value="#111430"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Мітка поля -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#3A3F62"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="4,0,0,7"/>
        </Style>

    </Window.Resources>

    <!-- Зовнішня тінь -->
    <Border>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="60"
                              ShadowDepth="0" Opacity="0.8"/>
        </Border.Effect>

        <!-- Вікно -->
        <Border CornerRadius="20" ClipToBounds="True">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#090C1C" Offset="0"/>
                    <GradientStop Color="#070918" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>

                <!-- ── ДЕКОРАТИВНИЙ ФОН ─────────────────────────── -->

                <!-- Велике коло зверху-зліва -->
                <Ellipse Width="320" Height="320"
                         HorizontalAlignment="Left" VerticalAlignment="Top"
                         Margin="-120,-120,0,0">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#1A1560" Offset="0"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- Мале коло знизу-справа -->
                <Ellipse Width="260" Height="260"
                         HorizontalAlignment="Right" VerticalAlignment="Bottom"
                         Margin="0,0,-80,-80">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#120E40" Offset="0"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- Тонка діагональна лінія-акцент -->
                <Line X1="0" Y1="180" X2="440" Y2="320"
                      Stroke="#1A1F40" StrokeThickness="1"
                      Opacity="0.5"/>

                <!-- ── КОНТЕНТ ───────────────────────────────────── -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Drag + кнопка закрити -->
                    <Grid Grid.Row="0" MouseDown="DragWindow">
                        <Button Content="✕"
                                HorizontalAlignment="Right"
                                Width="40" Height="40"
                                Click="CloseButton_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background"      Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Foreground"      Value="#252A45"/>
                                    <Setter Property="Cursor"          Value="Hand"/>
                                    <Setter Property="FontSize"        Value="13"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="0,20,0,0">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#2A1020"/>
                                                        <Setter Property="Foreground" Value="#F87171"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>

                    <!-- Форма -->
                    <StackPanel Grid.Row="1" Margin="44,0,44,44">

                        <!-- Логотип -->
                        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,32">
                            <Border Width="56" Height="56" CornerRadius="16"
                                    HorizontalAlignment="Center" Margin="0,0,0,14">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#4A3FC0" Offset="0"/>
                                        <GradientStop Color="#8B7FE8" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#6C63FF" BlurRadius="20"
                                                      ShadowDepth="0" Opacity="0.5"/>
                                </Border.Effect>
                                <TextBlock Text="✦" FontSize="24" Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock Text="GymCRM"
                                       FontFamily="Segoe UI"
                                       FontSize="24" FontWeight="Bold"
                                       Foreground="#E8E4FF"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Система управління фітнес-клубом"
                                       FontFamily="Segoe UI"
                                       FontSize="10"
                                       Foreground="#252A45"
                                       HorizontalAlignment="Center"
                                       Margin="0,5,0,0"/>
                        </StackPanel>

                        <!-- Email -->
                        <TextBlock Text="EMAIL" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="EmailBox"
                                 Style="{StaticResource LoginField}"
                                 Margin="0,0,0,16"
                                 KeyDown="OnKeyDown"/>

                        <!-- Пароль -->
                        <TextBlock Text="ПАРОЛЬ" Style="{StaticResource FieldLabel}"/>
                        <PasswordBox x:Name="PasswordBox"
                                     Style="{StaticResource LoginPass}"
                                     Margin="0,0,0,4"
                                     KeyDown="OnKeyDown"/>

                        <!-- Помилка -->
                        <Border x:Name="ErrorBorder"
                                Visibility="Collapsed"
                                Background="#1A0B0B"
                                BorderBrush="#3D1A1A"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="14,9"
                                Margin="0,12,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠" Foreground="#F87171"
                                           FontSize="12" Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="ErrorText"
                                           Foreground="#F87171"
                                           FontFamily="Segoe UI"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Кнопка входу -->
                        <Button x:Name="LoginBtn"
                                Height="48"
                                Margin="0,20,0,0"
                                Cursor="Hand"
                                Click="LoginButton_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FontFamily"      Value="Segoe UI"/>
                                    <Setter Property="FontSize"        Value="14"/>
                                    <Setter Property="FontWeight"      Value="SemiBold"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="btn" CornerRadius="13">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#4A3FC0" Offset="0"/>
                                                            <GradientStop Color="#7B6FD0" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#6C63FF" BlurRadius="20"
                                                                          ShadowDepth="0" Opacity="0.4"/>
                                                    </Border.Effect>
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="btn" Property="Opacity" Value="0.85"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="btn" Property="Opacity" Value="0.4"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="Увійти" Foreground="White"
                                       FontFamily="Segoe UI"
                                       FontSize="14" FontWeight="SemiBold"/>
                        </Button>

                        <!-- Версія -->
                        <TextBlock Text="v1.0  ·  GymCRM"
                                   FontFamily="Segoe UI"
                                   Foreground="#1A1F38"
                                   FontSize="10"
                                   HorizontalAlignment="Center"
                                   Margin="0,22,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
