<Window x:Class="FitnessClub.Desktop.Views.Dialogs.TrainerProfileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Профіль тренера" Height="640" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent">

    <Border CornerRadius="16" Background="#0d1020" BorderBrush="#1a1f35" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="120"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <!-- Шапка -->
            <Border Grid.Row="0" CornerRadius="16,16,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1a1744" Offset="0"/>
                        <GradientStop Color="#2d1f6e" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="72" Height="72" CornerRadius="36" VerticalAlignment="Center"
                            BorderBrush="#2d2060" BorderThickness="3">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#6C63FF" Offset="0"/>
                                <GradientStop Color="#a78bfa" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock x:Name="InitialsText" Foreground="White" FontSize="24"
                                   FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0">
                        <TextBlock x:Name="NameText" Foreground="White" FontSize="20" FontWeight="Bold"/>
                        <TextBlock x:Name="SpecText" Foreground="#a78bfa" FontSize="12" Margin="0,2,0,0"/>
                        <TextBlock x:Name="EmailText" Foreground="#4b5563" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="✕" Width="36" Height="36"
                            VerticalAlignment="Top" Margin="0,8,0,0"
                            Cursor="Hand" Click="Close_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Foreground" Value="#6b7280"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="#f87171"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,20,24,0">

                    <!-- Статистика -->
                    
                    <UniformGrid Columns="4" Margin="0,0,0,16">
                        <Border Margin="0,0,8,0" CornerRadius="14" Padding="14">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1a1744" Offset="0"/>
                                    <GradientStop Color="#2d1f6e" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel>
                                <TextBlock Text="Досвід" Foreground="#7c6fbf" FontSize="10"/>
                                <TextBlock x:Name="ExpText" Foreground="#a78bfa"
                                           FontSize="22" FontWeight="Bold"/>
                                <TextBlock Text="років" Foreground="#4b5563" FontSize="9"/>
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,8,0" CornerRadius="14" Padding="14">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#053d2e" Offset="0"/>
                                    <GradientStop Color="#065f46" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel>
                                <TextBlock Text="Занять" Foreground="#2d8a6a" FontSize="10"/>
                                <TextBlock x:Name="SessionsText" Foreground="#34d399"
                                           FontSize="22" FontWeight="Bold"/>
                                <TextBlock Text="завершено" Foreground="#4b5563" FontSize="9"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Margin="0,0,8,0" CornerRadius="14" Padding="14">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#3d2a03" Offset="0"/>
                                    <GradientStop Color="#7c5a12" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel>
                                <TextBlock Text="Ставка" Foreground="#a07a2d" FontSize="10"/>
                                <TextBlock x:Name="RateText" Foreground="#f59e0b"
                                           FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="₴/год" Foreground="#4b5563" FontSize="9"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="14" Padding="14">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0f2a4a" Offset="0"/>
                                    <GradientStop Color="#1e40af" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel>
                                <TextBlock Text="В компанії" Foreground="#3a6abf" FontSize="10"/>
                                <TextBlock x:Name="TenureText" Foreground="#60a5fa"
                                           FontSize="14" FontWeight="Bold" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Контакти -->
                    <Border Background="#131929" CornerRadius="14" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="📞 Контактна інформація" Foreground="White"
                                       FontSize="13" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Телефон" Foreground="#4b5563" FontSize="11"/>
                                    <TextBlock x:Name="PhoneText" Foreground="#9ca3af"
                                               FontSize="13" Margin="0,3,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Email" Foreground="#4b5563" FontSize="11"/>
                                    <TextBlock x:Name="EmailInfoText" Foreground="#9ca3af"
                                               FontSize="13" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Bio -->
                    <Border x:Name="BioPanel" Background="#131929" CornerRadius="14"
                            Padding="16" Margin="0,0,0,12" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="📝 Про тренера" Foreground="White"
                                       FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock x:Name="BioText" Foreground="#9ca3af"
                                       FontSize="12" TextWrapping="Wrap" LineHeight="20"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#131929" CornerRadius="14" Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="💳 Вартість послуг" Foreground="White"
                   FontSize="13" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <UniformGrid Columns="3">
                                <Border Margin="0,0,8,0" CornerRadius="12" Padding="16,12">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#1e1b4b" Offset="0"/>
                                            <GradientStop Color="#2d2a6e" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="👥 Групове" Foreground="#7c6fbf"
                               FontSize="10" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="GroupRateText" Foreground="#a78bfa"
                               FontSize="20" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                        <TextBlock Text="за заняття" Foreground="#4b5563"
                               FontSize="9" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,0,8,0" CornerRadius="12" Padding="16,12">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#053d2e" Offset="0"/>
                                            <GradientStop Color="#065f46" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="👤 Індивідуальне" Foreground="#2d8a6a"
                               FontSize="10" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="IndividualRateText" Foreground="#34d399"
                               FontSize="20" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                        <TextBlock Text="за заняття" Foreground="#4b5563"
                               FontSize="9" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border CornerRadius="12" Padding="16,12">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#3d2a03" Offset="0"/>
                                            <GradientStop Color="#7c5a12" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="📅 Місячний план" Foreground="#a07a2d"
                               FontSize="10" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="MonthlyRateText" Foreground="#f59e0b"
                               FontSize="20" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                        <TextBlock Text="на місяць" Foreground="#4b5563"
                               FontSize="9" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <!-- Останні заняття -->
                    <Border Background="#131929" CornerRadius="14" Padding="16">
                        <StackPanel>
                            <TextBlock Text="📅 Останні заняття" Foreground="White"
                                       FontSize="13" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <ListView x:Name="SchedulesList" Background="Transparent"
                                      BorderThickness="0" Foreground="White" MaxHeight="200">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0,6"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListViewItem">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="#1a1f35" BorderThickness="0,0,0,1"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding ClassName}" Foreground="White"
                                                       FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding DateStr}"
                                                       Foreground="#6b7280" FontSize="11" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding BookingsCount}"
                                                       Foreground="#a78bfa" FontSize="12"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <Border Grid.Column="3" CornerRadius="6" Padding="6,3">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#1a2e1a"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                                <Setter Property="Background" Value="#2d1f1f"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Scheduled">
                                                                <Setter Property="Background" Value="#1e1b4b"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding StatusUa}" FontSize="10">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#34d399"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                                    <Setter Property="Foreground" Value="#f87171"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Scheduled">
                                                                    <Setter Property="Foreground" Value="#a78bfa"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="#131929" CornerRadius="0,0,16,16" Padding="24,0">
                <Button Content="Закрити" Height="40" HorizontalAlignment="Right"
                        Width="120" Cursor="Hand" Click="Close_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#1a1f35"/>
                            <Setter Property="Foreground" Value="#9ca3af"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#252b45"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Border>
        </Grid>
    </Border>
</Window>