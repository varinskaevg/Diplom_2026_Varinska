<!-- AddTrainerClientDialog.xaml                              -->
<!-- ══════════════════════════════════════════════════════════ -->
<Window x:Class="FitnessClub.Desktop.Views.Dialogs.AddTrainerClientDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Прив'язати клієнта"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="#080b18"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize">

    <Border Padding="28">
        <StackPanel>
            <!-- Заголовок -->
            <TextBlock Text="👥 Прив'язати клієнта до тренера"
                       Foreground="White" FontSize="17" FontWeight="Bold" Margin="0,0,0,20"/>

            <!-- Клієнт -->
            <TextBlock Text="Клієнт *" Foreground="#8888aa" FontSize="11" Margin="0,0,0,6"/>
            <Border Background="#1a1f35" CornerRadius="10" Margin="0,0,0,14">
                <ComboBox x:Name="ClientBox" Background="Transparent" Foreground="Black"
                          BorderThickness="0" Padding="12,9" FontSize="13"
                          IsEditable="True" IsTextSearchEnabled="True"/>
            </Border>

            <!-- Тип оплати -->
            <TextBlock Text="Тип оплати *" Foreground="#8888aa" FontSize="11" Margin="0,0,0,6"/>
            <Border Background="#1a1f35" CornerRadius="10" Margin="0,0,0,14">
                <ComboBox x:Name="PaymentTypeBox" Background="Transparent" Foreground="Black"
                          BorderThickness="0" Padding="12,9" FontSize="13"
                          SelectionChanged="PaymentType_Changed">
                    <ComboBoxItem Tag="single" Content="Разова оплата" IsSelected="True"/>
                    <ComboBoxItem Tag="weekly" Content="Тижнева оплата"/>
                    <ComboBoxItem Tag="monthly" Content="Mісячна оплата"/>
                </ComboBox>
            </Border>

            <!-- Ставка -->
            <TextBlock Text="Ставка (₴) *" Foreground="#8888aa" FontSize="11" Margin="0,0,0,6"/>
            <Border Background="#1a1f35" BorderBrush="#2a2f45" BorderThickness="1"
                    CornerRadius="10" Margin="0,0,0,14">
                <TextBox x:Name="RateBox" Background="Transparent" Foreground="White"
                         BorderThickness="0" Padding="12,10" FontSize="13"
                         CaretBrush="White" Text="0"/>
            </Border>

            <!-- Метод оплати -->
            <TextBlock Text="Метод оплати" Foreground="#8888aa" FontSize="11" Margin="0,0,0,6"/>
            <Border Background="#1a1f35" CornerRadius="10" Margin="0,0,0,14">
                <ComboBox x:Name="PaymentMethodBox" Background="Transparent" Foreground="Black"
                          BorderThickness="0" Padding="12,9" FontSize="13">
                    <ComboBoxItem Tag="Cash" Content="Готівка" IsSelected="True"/>
                    <ComboBoxItem Tag="Card" Content="Картка"/>
                    <ComboBoxItem Tag="Online" Content="Онлайн"/>
                </ComboBox>
            </Border>

            <!-- Оплатити зараз (тільки для разової) -->
            <StackPanel x:Name="PayNowPanel" Orientation="Horizontal" Margin="0,0,0,14">
                <CheckBox x:Name="PayNowCheckBox" IsChecked="True" VerticalAlignment="Center"
                          Foreground="White" FontSize="12" Content="✅ Оплатити зараз (перший платіж)"/>
            </StackPanel>

            <!-- Нотатки -->
            <TextBlock Text="Нотатки" Foreground="#8888aa" FontSize="11" Margin="0,0,0,6"/>
            <Border Background="#1a1f35" BorderBrush="#2a2f45" BorderThickness="1"
                    CornerRadius="10" Margin="0,0,0,20">
                <TextBox x:Name="NotesBox" Background="Transparent" Foreground="White"
                         BorderThickness="0" Padding="12,10" FontSize="12"
                         AcceptsReturn="True" Height="60" TextWrapping="Wrap"
                         CaretBrush="White"/>
            </Border>

            <!-- Кнопки -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Content="Скасувати" Height="40" Cursor="Hand" Click="Cancel_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#1a1f35"/>
                            <Setter Property="Foreground" Value="#9ca3af"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#252b45"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="SaveBtn" Grid.Column="2" Content="✅ Прив'язати"
                        Height="40" Cursor="Hand" Click="Save_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#065f46"/>
                            <Setter Property="Foreground" Value="#34d399"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#047857"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </StackPanel>
    </Border>
</Window>

