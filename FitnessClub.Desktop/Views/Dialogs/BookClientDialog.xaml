<Window x:Class="FitnessClub.Desktop.Views.Dialogs.BookClientDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Запис клієнта" Height="560" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent">

    <Border CornerRadius="16" Background="#0d1020" BorderBrush="#1a1f35" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <!-- Хедер -->
            <Grid Grid.Row="0" Background="#131929">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="👤" FontSize="18" Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock x:Name="TitleText" Foreground="White"
                                   FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock x:Name="SubtitleText" Foreground="#6b7280" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
                <Button Grid.Column="1" Content="✕" Width="40" Height="40"
                        Cursor="Hand" Click="Cancel_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="#6b7280"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="0,16,0,0">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#3d1f1f"/>
                                                <Setter Property="Foreground" Value="#f87171"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Пошук -->
            <Border Grid.Row="1" Margin="16,12,16,8"
                    Background="#1a1f35" BorderBrush="#2a2f45"
                    BorderThickness="1" CornerRadius="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🔍" FontSize="14" Margin="12,0,0,0"
                               VerticalAlignment="Center" Foreground="#4b5563"/>
                    <TextBox x:Name="SearchBox" Grid.Column="1"
                             Background="Transparent" Foreground="White"
                             BorderThickness="0" FontSize="13" Padding="8,10"
                             CaretBrush="White" TextChanged="Search_Changed"/>
                </Grid>
            </Border>

            <!-- Список клієнтів -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="12,0,12,0">
                <ItemsControl x:Name="ClientsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10" Margin="4,0,4,6"
                                    Padding="14,10" Cursor="Hand"
                                    MouseLeftButtonUp="SelectClient_Click">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#131929"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background" Value="#1e1b4b"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1a1f35"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="32" Height="32" CornerRadius="16">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#1e1b4b" Offset="0"/>
                                                <GradientStop Color="#2d2a6e" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="{Binding Initials}" Foreground="#a78bfa"
                                                   FontSize="12" FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FullName}" Foreground="White"
                                                   FontSize="13" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Phone}" Foreground="#6b7280"
                                                   FontSize="11"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" CornerRadius="6" Padding="8,3"
                                            VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#0d2a1a"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasMembership}" Value="False">
                                                        <Setter Property="Background" Value="#2d1f1f"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IncludesClasses}" Value="False">
                                                        <Setter Property="Background" Value="#3d2a03"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding MembershipStatus}"
                                                   FontSize="10" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#34d399"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasMembership}" Value="False">
                                                            <Setter Property="Foreground" Value="#f87171"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IncludesClasses}" Value="False">
                                                            <Setter Property="Foreground" Value="#f59e0b"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Кнопки -->
            <Grid Grid.Row="3" Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Скасувати" Height="42"
                        Cursor="Hand" Click="Cancel_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#1a1f35"/>
                            <Setter Property="Foreground" Value="#9ca3af"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="BookBtn" Grid.Column="2" Content="✅  Записати"
                        Height="42" Cursor="Hand" Click="Book_Click" IsEnabled="False">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#6C63FF"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#5a52e0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>