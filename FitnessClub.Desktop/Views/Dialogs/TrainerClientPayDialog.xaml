<!-- TrainerClientPayDialog.xaml                              -->
<!-- ══════════════════════════════════════════════════════════ -->
<Window x:Class="FitnessClub.Desktop.Views.Dialogs.TrainerClientPayDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Прийняти оплату"
        Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="#080b18"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize">

    <Border Padding="28">
        <StackPanel>
            <TextBlock x:Name="TitleText" Text="💳 Прийняти оплату"
                       Foreground="White" FontSize="17" FontWeight="Bold" Margin="0,0,0,20"/>

            <!-- Сума -->
            <TextBlock Text="Сума (₴) *" Foreground="#8888aa" FontSize="11" Margin="0,0,0,6"/>
            <Border Background="#1a1f35" BorderBrush="#2a2f45" BorderThickness="1"
                    CornerRadius="10" Margin="0,0,0,14">
                <TextBox x:Name="AmountBox" Background="Transparent" Foreground="White"
                         BorderThickness="0" Padding="12,10" FontSize="15" FontWeight="Bold"
                         CaretBrush="White"/>
            </Border>

            <!-- Метод -->
            <TextBlock Text="Метод оплати" Foreground="#8888aa" FontSize="11" Margin="0,0,0,6"/>
            <Border Background="#1a1f35" CornerRadius="10" Margin="0,0,0,14">
                <ComboBox x:Name="PaymentMethodBox" Background="Transparent" Foreground="White"
                          BorderThickness="0" Padding="12,9" FontSize="13">
                    <ComboBoxItem Tag="Cash" Content="💵 Готівка" IsSelected="True"/>
                    <ComboBoxItem Tag="Card" Content="💳 Картка"/>
                    <ComboBoxItem Tag="Online" Content="📱 Онлайн"/>
                </ComboBox>
            </Border>

            <!-- Дата платежу -->
            <TextBlock Text="Дата платежу" Foreground="#8888aa" FontSize="11" Margin="0,0,0,6"/>
            <Border Background="#1a1f35" CornerRadius="10" Margin="0,0,0,14">
                <DatePicker x:Name="PaidAtPicker" Background="Transparent"
                            Foreground="White" BorderThickness="0" Padding="8,6"/>
            </Border>

            <!-- Примітка -->
            <TextBlock Text="Примітка" Foreground="#8888aa" FontSize="11" Margin="0,0,0,6"/>
            <Border Background="#1a1f35" BorderBrush="#2a2f45" BorderThickness="1"
                    CornerRadius="10" Margin="0,0,0,20">
                <TextBox x:Name="NoteBox" Background="Transparent" Foreground="White"
                         BorderThickness="0" Padding="12,10" FontSize="12"
                         CaretBrush="White"/>
            </Border>

            <!-- Кнопки -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Content="Скасувати" Height="40" Cursor="Hand" Click="Cancel_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#1a1f35"/>
                            <Setter Property="Foreground" Value="#9ca3af"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#252b45"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="PayBtn" Grid.Column="2" Content="💳 Прийняти оплату"
                        Height="40" Cursor="Hand" Click="Pay_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#065f46"/>
                            <Setter Property="Foreground" Value="#34d399"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#047857"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </StackPanel>
    </Border>
</Window>
