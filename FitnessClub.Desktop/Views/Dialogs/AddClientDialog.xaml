<Window x:Class="FitnessClub.Desktop.Views.Dialogs.AddClientDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новий клієнт" Height="580" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="16" Background="#0d1020"
            BorderBrush="#1a1f35" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Grid Grid.Row="0" Background="#131929">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="👤" FontSize="18" Margin="0,0,10,0"/>
                    <TextBlock Text="Новий клієнт" Foreground="White" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Content="✕" Width="40" Height="40"
                        Foreground="#6b7280" Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Click="Cancel_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="#6b7280"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="0,16,0,0">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#3d1f1f"/>
                                                <Setter Property="Foreground" Value="#f87171"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Форма -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,20,24,0">

                    <!-- Ім'я -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Ім'я *" Foreground="#8888aa" FontSize="12" Margin="0,0,0,6"/>
                            <Border Background="#1a1f35" BorderBrush="#2a2f45" BorderThickness="1" CornerRadius="10">
                                <TextBox x:Name="FirstNameBox" Background="Transparent" Foreground="White"
                                         BorderThickness="0" FontSize="13" Padding="12,10" CaretBrush="White"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Прізвище *" Foreground="#8888aa" FontSize="12" Margin="0,0,0,6"/>
                            <Border Background="#1a1f35" BorderBrush="#2a2f45" BorderThickness="1" CornerRadius="10">
                                <TextBox x:Name="LastNameBox" Background="Transparent" Foreground="White"
                                         BorderThickness="0" FontSize="13" Padding="12,10" CaretBrush="White"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Email -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Email *" Foreground="#8888aa" FontSize="12" Margin="0,0,0,6"/>
                        <Border Background="#1a1f35" BorderBrush="#2a2f45" BorderThickness="1" CornerRadius="10">
                            <TextBox x:Name="EmailBox" Background="Transparent" Foreground="White"
                                     BorderThickness="0" FontSize="13" Padding="12,10" CaretBrush="White"/>
                        </Border>
                    </StackPanel>

                    <!-- Пароль -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Пароль *" Foreground="#8888aa" FontSize="12" Margin="0,0,0,6"/>
                        <Border Background="#1a1f35" BorderBrush="#2a2f45" BorderThickness="1" CornerRadius="10">
                            <PasswordBox x:Name="PasswordBox" Background="Transparent" Foreground="White"
                                         BorderThickness="0" FontSize="13" Padding="12,10"/>
                        </Border>
                    </StackPanel>

                    <!-- Телефон -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Телефон" Foreground="#8888aa" FontSize="12" Margin="0,0,0,6"/>
                        <Border Background="#1a1f35" BorderBrush="#2a2f45" BorderThickness="1" CornerRadius="10">
                            <TextBox x:Name="PhoneBox" Background="Transparent" Foreground="White"
                                     BorderThickness="0" FontSize="13" Padding="12,10" CaretBrush="White"/>
                        </Border>
                    </StackPanel>

                    <!-- Дата народження + Стать -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Дата народження" Foreground="#8888aa" FontSize="12" Margin="0,0,0,6"/>
                            <Border Background="#1a1f35" BorderBrush="#2a2f45" BorderThickness="1" CornerRadius="10">
                                <DatePicker x:Name="BirthDatePicker" Background="Transparent"
                                            Foreground="White" BorderThickness="0" Padding="8,6"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Стать" Foreground="#8888aa" FontSize="12" Margin="0,0,0,6"/>
                            <Border Background="#1a1f35" BorderBrush="#2a2f45" BorderThickness="1" CornerRadius="10">
                                <ComboBox x:Name="GenderBox" Background="Transparent" Foreground="Black"
                                          BorderThickness="0" Padding="8,6">
                                    <ComboBoxItem Content="Male"/>
                                    <ComboBoxItem Content="Female"/>
                                    <ComboBoxItem Content="Other"/>
                                </ComboBox>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Нотатки здоров'я -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Медичні нотатки" Foreground="#8888aa" FontSize="12" Margin="0,0,0,6"/>
                        <Border Background="#1a1f35" BorderBrush="#2a2f45" BorderThickness="1" CornerRadius="10">
                            <TextBox x:Name="HealthNotesBox" Background="Transparent" Foreground="White"
                                     BorderThickness="0" FontSize="13" Padding="12,10"
                                     CaretBrush="White" TextWrapping="Wrap"
                                     AcceptsReturn="True" Height="70"/>
                        </Border>
                    </StackPanel>

                    <!-- Помилка -->
                    <TextBlock x:Name="ErrorText" Foreground="#f87171" FontSize="12"
                               Visibility="Collapsed" TextWrapping="Wrap" Margin="0,0,0,8"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Кнопки -->
            <Grid Grid.Row="2" Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Скасувати" Height="42" Cursor="Hand" Click="Cancel_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#1a1f35"/>
                            <Setter Property="Foreground" Value="#9ca3af"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Grid.Column="2" Content="Зберегти" Height="42" Cursor="Hand" Click="Save_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#6C63FF"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>