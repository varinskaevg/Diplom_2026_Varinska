<Window x:Class="FitnessClub.Desktop.Views.Dialogs.EditScheduleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Заняття" Height="600" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent">

    <Window.Resources>
        <!-- Стиль поля вводу -->
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="Foreground"     Value="#E2DFF8"/>
            <Setter Property="CaretBrush"     Value="#A78BFA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily"     Value="Segoe UI"/>
            <Setter Property="FontSize"       Value="13"/>
            <Setter Property="Padding"        Value="14,11"/>
            <Setter Property="SelectionBrush" Value="#6C63FF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bg"
                                Background="#111528"
                                BorderBrush="#1E2540"
                                BorderThickness="1"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bg" Property="BorderBrush" Value="#6C63FF"/>
                                <Setter TargetName="bg" Property="Background"  Value="#131830"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ToggleButton всередині ComboBox -->
        <Style x:Key="ComboToggle" TargetType="ToggleButton">
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Focusable"      Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent">
                            <TextBlock Text="▾" Foreground="#4A4F6A"
                                       FontSize="11"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="0,0,14,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль ComboBox -->
        <Style x:Key="FieldCombo" TargetType="ComboBox">
            <Setter Property="Background"      Value="#111528"/>
            <Setter Property="Foreground"      Value="#E2DFF8"/>
            <Setter Property="BorderBrush"     Value="#1E2540"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Padding"         Value="14,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- Фон + бордер -->
                            <Border x:Name="bg"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10"/>

                            <!-- ToggleButton покриває весь контрол — він і відкриває список -->
                            <ToggleButton Style="{StaticResource ComboToggle}"
                                          Focusable="False"
                                          IsChecked="{Binding Path=IsDropDownOpen,
                                              Mode=TwoWay,
                                              RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"/>

                            <!-- Вибраний елемент -->
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>

                            <!-- Випадаючий список -->
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide"
                                   Placement="Bottom">
                                <Border Background="#131830"
                                        BorderBrush="#2A2F50"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="220">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" BlurRadius="20"
                                                          ShadowDepth="4" Opacity="0.5"/>
                                    </Border.Effect>
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="bg" Property="BorderBrush" Value="#6C63FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="BorderBrush" Value="#2A2F50"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground"  Value="#E2DFF8"/>
                        <Setter Property="Background"  Value="Transparent"/>
                        <Setter Property="FontFamily"  Value="Segoe UI"/>
                        <Setter Property="FontSize"    Value="13"/>
                        <Setter Property="Padding"     Value="14,9"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="itemBg" Background="Transparent"
                                            CornerRadius="6" Margin="4,1">
                                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="itemBg" Property="Background" Value="#1E2540"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="itemBg" Property="Background" Value="#2A2060"/>
                                            <Setter Property="Foreground" Value="#A78BFA"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Мітка поля -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#4A4F72"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="2,0,0,6"/>
        </Style>
    </Window.Resources>

    <!-- Зовнішня тінь -->
    <Border>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="50"
                              ShadowDepth="0" Opacity="0.7"/>
        </Border.Effect>

        <!-- Основне вікно -->
        <Border CornerRadius="18"
                BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0.3,1">
                    <GradientStop Color="#0C0F1E" Offset="0"/>
                    <GradientStop Color="#090C18" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#2A2F50" Offset="0"/>
                    <GradientStop Color="#141828" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="64"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="76"/>
                </Grid.RowDefinitions>

                <!-- ── ШАПКА ───────────────────────────────────── -->
                <Border Grid.Row="0" CornerRadius="18,18,0,0"
                        BorderBrush="#141828" BorderThickness="0,0,0,1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#0F1226" Offset="0"/>
                            <GradientStop Color="#0C0F1E" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid Margin="20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Іконка в кружечку -->
                            <Border Width="32" Height="32" CornerRadius="9" Margin="0,0,12,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#4A3FC0" Offset="0"/>
                                        <GradientStop Color="#7B6FD0" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="📅" FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="TitleText" Text="Нове заняття"
                                           Foreground="#E8E4FF"
                                           FontFamily="Segoe UI"
                                           FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Заповніть всі обов'язкові поля"
                                           Foreground="#2D3354"
                                           FontFamily="Segoe UI"
                                           FontSize="10"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Кнопка закрити -->
                        <Button Grid.Column="1" Width="32" Height="32"
                                Cursor="Hand" Click="Cancel_Click"
                                VerticalAlignment="Center">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background"     Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Foreground"     Value="#3A3F5C"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bg" CornerRadius="8"
                                                        Background="{TemplateBinding Background}">
                                                    <TextBlock Text="✕" FontSize="12"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Foreground="{TemplateBinding Foreground}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Background" Value="#2A1520"/>
                                                        <Setter Property="Foreground" Value="#F87171"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- ── ФОРМА ───────────────────────────────────── -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Hidden"
                              Padding="0,2">
                    <StackPanel Margin="24,18,24,4">

                        <!-- Тип заняття -->
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Text="ТИП ЗАНЯТТЯ *" Style="{StaticResource FieldLabel}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox x:Name="ClassTypeBox"
                                          Style="{StaticResource FieldCombo}"
                                          SelectionChanged="ClassTypeBox_SelectionChanged">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Border CornerRadius="5" Padding="5,2" Margin="0,0,8,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#1A0F30"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsIndividual}" Value="True">
                                                                    <Setter Property="Background" Value="#0F1A30"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="10">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text"       Value="👥"/>
                                                                <Setter Property="Foreground" Value="#C084FC"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsIndividual}" Value="True">
                                                                        <Setter Property="Text"       Value="👤"/>
                                                                        <Setter Property="Foreground" Value="#60A5FA"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                                <TextBlock Text="{Binding Name}"
                                                           Foreground="#E2DFF8"
                                                           FontSize="13"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <!-- Бейдж типу -->
                                <Border x:Name="ClassTypeBadge" Grid.Column="1"
                                        CornerRadius="8" Padding="10,5"
                                        Margin="8,0,0,0" VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="ClassTypeBadgeIcon"
                                                   FontSize="11" Margin="0,0,5,0"/>
                                        <TextBlock x:Name="ClassTypeBadgeLabel"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   FontFamily="Segoe UI"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <!-- Тренер -->
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Text="ТРЕНЕР *" Style="{StaticResource FieldLabel}"/>
                            <ComboBox x:Name="TrainerBox"
                                      Style="{StaticResource FieldCombo}"
                                      DisplayMemberPath="FullName"/>
                        </StackPanel>

                        <!-- Дата + час -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="130"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="ДАТА *" Style="{StaticResource FieldLabel}"/>
                                <Border Background="#111528" BorderBrush="#1E2540"
                                        BorderThickness="1" CornerRadius="10">
                                    <DatePicker x:Name="DatePicker"
                                                Background="Transparent"
                                                Foreground="#E2DFF8"
                                                BorderThickness="0"
                                                Padding="10,8"
                                                FontFamily="Segoe UI"
                                                FontSize="13"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource FieldLabel}">
                                    <Run Text="ЧАС ПОЧАТКУ *"/>
                                    <Run Text="(09–22)" Foreground="#2D3354"/>
                                </TextBlock>
                                <TextBox x:Name="StartTimeBox"
                                         Style="{StaticResource FieldBox}"
                                         Text="09:00"/>
                            </StackPanel>
                        </Grid>

                        <!-- Тривалість + зал -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="ТРИВАЛІСТЬ (ХВ)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="DurationBox"
                                         Style="{StaticResource FieldBox}"
                                         Text="60"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="ЗАЛ" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="RoomBox"
                                         Style="{StaticResource FieldBox}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Місця + статус -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="МАКС. МІСЦЬ" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="CapacityBox"
                                         Style="{StaticResource FieldBox}"
                                         Text="20"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" x:Name="StatusPanel" Visibility="Collapsed">
                                <TextBlock Text="СТАТУС" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="StatusBox" Style="{StaticResource FieldCombo}">
                                    <ComboBoxItem Content="Заплановано" Tag="Scheduled"/>
                                    <ComboBoxItem Content="Завершено"   Tag="Completed"/>
                                    <ComboBoxItem Content="Скасовано"   Tag="Cancelled"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <!-- Нотатки -->
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Text="НОТАТКИ" Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="NotesBox"
                                     Style="{StaticResource FieldBox}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Height="64"/>
                        </StackPanel>

                        <!-- Помилка -->
                        <Border x:Name="ErrorBorder" Visibility="Collapsed"
                                Background="#1A0B0B" BorderBrush="#4D1F1F"
                                BorderThickness="1" CornerRadius="10"
                                Padding="14,10" Margin="0,0,0,4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠" Foreground="#F87171"
                                           FontSize="13" Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="ErrorText"
                                           Foreground="#F87171"
                                           FontFamily="Segoe UI"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- ── КНОПКИ ──────────────────────────────────── -->
                <Border Grid.Row="2"
                        BorderBrush="#141828" BorderThickness="0,1,0,0"
                        CornerRadius="0,0,18,18">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#0C0F1E" Offset="0"/>
                            <GradientStop Color="#090C18" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid Margin="24,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Скасувати -->
                        <Button Grid.Column="0" Height="42" Cursor="Hand"
                                Click="Cancel_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background"     Value="#111528"/>
                                    <Setter Property="Foreground"     Value="#4A4F72"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="BorderBrush"    Value="#1E2540"/>
                                    <Setter Property="FontFamily"     Value="Segoe UI"/>
                                    <Setter Property="FontSize"       Value="13"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="10">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background"  Value="#161B30"/>
                                                        <Setter Property="Foreground"  Value="#9CA3AF"/>
                                                        <Setter Property="BorderBrush" Value="#2A3050"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="Скасувати" FontFamily="Segoe UI" FontSize="13"/>
                        </Button>

                        <!-- Зберегти -->
                        <Button Grid.Column="2" Height="42" Cursor="Hand"
                                Click="Save_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FontFamily"     Value="Segoe UI"/>
                                    <Setter Property="FontSize"       Value="13"/>
                                    <Setter Property="FontWeight"     Value="SemiBold"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="saveBg" CornerRadius="10">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#5046C8" Offset="0"/>
                                                            <GradientStop Color="#7B6FD0" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#6C63FF" BlurRadius="14"
                                                                          ShadowDepth="0" Opacity="0.4"/>
                                                    </Border.Effect>
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="saveBg" Property="Opacity" Value="0.88"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💾" FontSize="13" Margin="0,0,7,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Зберегти" Foreground="White"
                                           FontFamily="Segoe UI"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Border>
</Window>
