<Window x:Class="FitnessClub.Desktop.Views.Dialogs.EditTrainerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Тренер" Height="660" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent">

	<Border CornerRadius="16" Background="#0d1020" BorderBrush="#1a1f35" BorderThickness="1">
		<Border.Effect>
			<DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="0" Opacity="0.6"/>
		</Border.Effect>
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="60"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="70"/>
			</Grid.RowDefinitions>

			<Grid Grid.Row="0" Background="#131929">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>
				<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
					<TextBlock Text="🏋️" FontSize="18" Margin="0,0,10,0"/>
					<TextBlock x:Name="TitleText" Text="Новий тренер" Foreground="White"
                               FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
				</StackPanel>
				<Button Grid.Column="1" Content="✕" Width="40" Height="40" Cursor="Hand" Click="Cancel_Click">
					<Button.Style>
						<Style TargetType="Button">
							<Setter Property="Background" Value="Transparent"/>
							<Setter Property="BorderThickness" Value="0"/>
							<Setter Property="Foreground" Value="#6b7280"/>
							<Setter Property="Template">
								<Setter.Value>
									<ControlTemplate TargetType="Button">
										<Border Background="{TemplateBinding Background}" CornerRadius="0,16,0,0">
											<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Border>
										<ControlTemplate.Triggers>
											<Trigger Property="IsMouseOver" Value="True">
												<Setter Property="Background" Value="#3d1f1f"/>
												<Setter Property="Foreground" Value="#f87171"/>
											</Trigger>
										</ControlTemplate.Triggers>
									</ControlTemplate>
								</Setter.Value>
							</Setter>
						</Style>
					</Button.Style>
				</Button>
			</Grid>

			<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
				<StackPanel Margin="24,20,24,0">

					<!-- Ім'я + Прізвище -->
					<Grid Margin="0,0,0,16">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="12"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>
						<StackPanel>
							<TextBlock Text="Ім'я *" Foreground="#8888aa" FontSize="12" Margin="0,0,0,6"/>
							<Border Background="#1a1f35" BorderBrush="#2a2f45" BorderThickness="1" CornerRadius="10">
								<TextBox x:Name="FirstNameBox" Background="Transparent" Foreground="White"
                                         BorderThickness="0" FontSize="13" Padding="12,10" CaretBrush="White"/>
							</Border>
						</StackPanel>
						<StackPanel Grid.Column="2">
							<TextBlock Text="Прізвище *" Foreground="#8888aa" FontSize="12" Margin="0,0,0,6"/>
							<Border Background="#1a1f35" BorderBrush="#2a2f45" BorderThickness="1" CornerRadius="10">
								<TextBox x:Name="LastNameBox" Background="Transparent" Foreground="White"
                                         BorderThickness="0" FontSize="13" Padding="12,10" CaretBrush="White"/>
							</Border>
						</StackPanel>
					</Grid>

					<!-- Email -->
					<StackPanel x:Name="EmailPanel" Margin="0,0,0,16">
						<TextBlock Text="Email *" Foreground="#8888aa" FontSize="12" Margin="0,0,0,6"/>
						<Border Background="#1a1f35" BorderBrush="#2a2f45" BorderThickness="1" CornerRadius="10">
							<TextBox x:Name="EmailBox" Background="Transparent" Foreground="White"
                                     BorderThickness="0" FontSize="13" Padding="12,10" CaretBrush="White"/>
						</Border>
					</StackPanel>

					<!-- Пароль -->
					<StackPanel x:Name="PasswordPanel" Margin="0,0,0,16">
						<TextBlock Text="Пароль *" Foreground="#8888aa" FontSize="12" Margin="0,0,0,6"/>
						<Border Background="#1a1f35" BorderBrush="#2a2f45" BorderThickness="1" CornerRadius="10">
							<PasswordBox x:Name="PasswordBox" Background="Transparent" Foreground="White"
                                         BorderThickness="0" FontSize="13" Padding="12,10"/>
						</Border>
					</StackPanel>

					<!-- Телефон -->
					<StackPanel Margin="0,0,0,16">
						<TextBlock Text="Телефон" Foreground="#8888aa" FontSize="12" Margin="0,0,0,6"/>
						<Border Background="#1a1f35" BorderBrush="#2a2f45" BorderThickness="1" CornerRadius="10">
							<TextBox x:Name="PhoneBox" Background="Transparent" Foreground="White"
                                     BorderThickness="0" FontSize="13" Padding="12,10" CaretBrush="White"/>
						</Border>
					</StackPanel>

					<!-- Спеціалізація -->
					<StackPanel Margin="0,0,0,16">
						<TextBlock Text="Спеціалізація" Foreground="#8888aa" FontSize="12" Margin="0,0,0,6"/>
						<Border Background="#1a1f35" BorderBrush="#2a2f45" BorderThickness="1" CornerRadius="10">
							<TextBox x:Name="SpecializationBox" Background="Transparent" Foreground="White"
                                     BorderThickness="0" FontSize="13" Padding="12,10" CaretBrush="White"/>
						</Border>
					</StackPanel>

					<!-- Досвід + Ставка -->
					<Grid Margin="0,0,0,16">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="12"/>
							<ColumnDefinition Width="*"/>
						</Grid.ColumnDefinitions>
						<StackPanel>
							<TextBlock Text="Досвід (років)" Foreground="#8888aa" FontSize="12" Margin="0,0,0,6"/>
							<Border Background="#1a1f35" BorderBrush="#2a2f45" BorderThickness="1" CornerRadius="10">
								<TextBox x:Name="ExperienceBox" Background="Transparent" Foreground="White"
                                         BorderThickness="0" FontSize="13" Padding="12,10"
                                         CaretBrush="White" Text="0"/>
							</Border>
						</StackPanel>
						<StackPanel Grid.Column="2">
							<TextBlock Text="Ставка (₴/год)" Foreground="#8888aa" FontSize="12" Margin="0,0,0,6"/>
							<Border Background="#1a1f35" BorderBrush="#2a2f45" BorderThickness="1" CornerRadius="10">
								<TextBox x:Name="RateBox" Background="Transparent" Foreground="White"
                                         BorderThickness="0" FontSize="13" Padding="12,10"
                                         CaretBrush="White" Text="0"/>
							</Border>
						</StackPanel>
					</Grid>

					<!-- Вартість послуг -->
					<StackPanel Margin="0,0,0,16">
						<TextBlock Text="💳 Вартість послуг" Foreground="White"
                                   FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="10"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="10"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<StackPanel>
								<TextBlock Text="👥 Групове (₴)" Foreground="#8888aa" FontSize="11" Margin="0,0,0,6"/>
								<Border Background="#1a1f35" BorderBrush="#2a2f45" BorderThickness="1" CornerRadius="10">
									<TextBox x:Name="GroupRateBox" Background="Transparent" Foreground="White"
                                             BorderThickness="0" FontSize="13" Padding="12,10"
                                             CaretBrush="White" Text="0"/>
								</Border>
							</StackPanel>
							<StackPanel Grid.Column="2">
								<TextBlock Text="👤 Індивід. (₴)" Foreground="#8888aa" FontSize="11" Margin="0,0,0,6"/>
								<Border Background="#1a1f35" BorderBrush="#2a2f45" BorderThickness="1" CornerRadius="10">
									<TextBox x:Name="IndividualRateBox" Background="Transparent" Foreground="White"
                                             BorderThickness="0" FontSize="13" Padding="12,10"
                                             CaretBrush="White" Text="0"/>
								</Border>
							</StackPanel>
							<StackPanel Grid.Column="4">
								<TextBlock Text="📅 Міс. план (₴)" Foreground="#8888aa" FontSize="11" Margin="0,0,0,6"/>
								<Border Background="#1a1f35" BorderBrush="#2a2f45" BorderThickness="1" CornerRadius="10">
									<TextBox x:Name="MonthlyPlanRateBox" Background="Transparent" Foreground="White"
                                             BorderThickness="0" FontSize="13" Padding="12,10"
                                             CaretBrush="White" Text="0"/>
								</Border>
							</StackPanel>
						</Grid>
					</StackPanel>

					<!-- Bio -->
					<StackPanel Margin="0,0,0,16">
						<TextBlock Text="Про тренера (Bio)" Foreground="#8888aa" FontSize="12" Margin="0,0,0,6"/>
						<Border Background="#1a1f35" BorderBrush="#2a2f45" BorderThickness="1" CornerRadius="10">
							<TextBox x:Name="BioBox" Background="Transparent" Foreground="White"
                                     BorderThickness="0" FontSize="13" Padding="12,10"
                                     CaretBrush="White" TextWrapping="Wrap"
                                     AcceptsReturn="True" Height="70"/>
						</Border>
					</StackPanel>

					<TextBlock x:Name="ErrorText" Foreground="#f87171" FontSize="12"
                               Visibility="Collapsed" TextWrapping="Wrap"/>
				</StackPanel>
			</ScrollViewer>

			<Grid Grid.Row="2" Margin="24,0">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="12"/>
					<ColumnDefinition Width="*"/>
				</Grid.ColumnDefinitions>
				<Button Grid.Column="0" Content="Скасувати" Height="42" Cursor="Hand" Click="Cancel_Click">
					<Button.Style>
						<Style TargetType="Button">
							<Setter Property="Background" Value="#1a1f35"/>
							<Setter Property="Foreground" Value="#9ca3af"/>
							<Setter Property="BorderThickness" Value="0"/>
							<Setter Property="FontSize" Value="13"/>
							<Setter Property="Template">
								<Setter.Value>
									<ControlTemplate TargetType="Button">
										<Border Background="{TemplateBinding Background}" CornerRadius="10">
											<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Border>
										<ControlTemplate.Triggers>
											<Trigger Property="IsMouseOver" Value="True">
												<Setter Property="Opacity" Value="0.8"/>
											</Trigger>
										</ControlTemplate.Triggers>
									</ControlTemplate>
								</Setter.Value>
							</Setter>
						</Style>
					</Button.Style>
				</Button>
				<Button Grid.Column="2" Content="💾  Зберегти" Height="42" Cursor="Hand" Click="Save_Click">
					<Button.Style>
						<Style TargetType="Button">
							<Setter Property="Background" Value="#6C63FF"/>
							<Setter Property="Foreground" Value="White"/>
							<Setter Property="BorderThickness" Value="0"/>
							<Setter Property="FontSize" Value="13"/>
							<Setter Property="FontWeight" Value="SemiBold"/>
							<Setter Property="Template">
								<Setter.Value>
									<ControlTemplate TargetType="Button">
										<Border Background="{TemplateBinding Background}" CornerRadius="10">
											<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Border>
										<ControlTemplate.Triggers>
											<Trigger Property="IsMouseOver" Value="True">
												<Setter Property="Background" Value="#5a52e0"/>
											</Trigger>
										</ControlTemplate.Triggers>
									</ControlTemplate>
								</Setter.Value>
							</Setter>
						</Style>
					</Button.Style>
				</Button>
			</Grid>
		</Grid>
	</Border>
</Window>