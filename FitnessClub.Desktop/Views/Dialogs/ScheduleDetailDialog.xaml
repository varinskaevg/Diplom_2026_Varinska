<Window x:Class="FitnessClub.Desktop.Views.Dialogs.ScheduleDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Деталі заняття" Height="580" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="None"
        AllowsTransparency="True" Background="Transparent">

    <Border CornerRadius="16" Background="#0d1020" BorderBrush="#1a1f35" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#131929">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                    <TextBlock Text="📅" FontSize="18" Margin="0,0,10,0"/>
                    <TextBlock x:Name="TitleText" Foreground="White"
                               FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="EditBtn" Content="✏️  Редагувати"
                            Height="36" Padding="14,0" Margin="0,0,8,0"
                            Cursor="Hand" Click="Edit_Click" Visibility="Collapsed">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#1a1f35"/>
                                <Setter Property="Foreground" Value="#9ca3af"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                  Margin="{TemplateBinding Padding}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#252b45"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="✕" Width="40" Height="40" Cursor="Hand" Click="Close_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Foreground" Value="#6b7280"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="0,16,0,0">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#3d1f1f"/>
                                                    <Setter Property="Foreground" Value="#f87171"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,20,24,0">

                    <!-- Інфо картка -->
                    <Border Background="#131929" CornerRadius="16" Padding="20" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="⏰ Час" Foreground="#4b5563" FontSize="11"/>
                                <TextBlock x:Name="TimeText" Foreground="White"
                                           FontSize="14" FontWeight="Bold" Margin="0,4,0,0"/>
                                <TextBlock x:Name="DurationText" Foreground="#6b7280" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="🏋️ Тренер" Foreground="#4b5563" FontSize="11"/>
                                <TextBlock x:Name="TrainerText" Foreground="#a78bfa"
                                           FontSize="13" FontWeight="SemiBold" Margin="0,4,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="📍 Зал" Foreground="#4b5563" FontSize="11"/>
                                <TextBlock x:Name="RoomText" Foreground="#9ca3af"
                                           FontSize="13" Margin="0,4,0,0"/>
                                <TextBlock x:Name="StatusText" FontSize="11"
                                           FontWeight="SemiBold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Завантаженість -->
                    <Border Background="#131929" CornerRadius="16" Padding="20" Margin="0,0,0,16">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="👥 Завантаженість залу" Foreground="White"
                                           FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" x:Name="CapacityText"
                                           Foreground="#a78bfa" FontSize="13" FontWeight="Bold"/>
                            </Grid>
                            <Border Height="8" CornerRadius="4" Background="#1a1f35">
                                <Border x:Name="LoadBar" Height="8" CornerRadius="4"
                                        HorizontalAlignment="Left">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#6C63FF" Offset="0"/>
                                            <GradientStop Color="#a78bfa" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Нотатки -->
                    <Border x:Name="NotesPanel" Background="#131929" CornerRadius="16"
                            Padding="20" Margin="0,0,0,16" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="📝 Нотатки" Foreground="White"
                                       FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock x:Name="NotesText" Foreground="#9ca3af"
                                       FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Список записаних -->
                    <Border Background="#131929" CornerRadius="16" Padding="20">
                        <StackPanel>
                            <TextBlock Text="📋 Записані клієнти" Foreground="White"
                                       FontSize="13" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <ListView x:Name="BookingsList" Background="Transparent"
                                      BorderThickness="0" Foreground="White" MaxHeight="200">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0,6"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListViewItem">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="#1a1f35" BorderThickness="0,0,0,1"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="32"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="26" Height="26" CornerRadius="13">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#6C63FF" Offset="0"/>
                                                        <GradientStop Color="#a78bfa" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock Text="{Binding Initials}" Foreground="White"
                                                           FontSize="9" FontWeight="Bold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding ClientName}"
                                                       Foreground="White" FontSize="12" VerticalAlignment="Center"
                                                       Margin="8,0,0,0"/>
                                            <Border Grid.Column="2" CornerRadius="6" Padding="8,3">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#0d2a1a"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                                <Setter Property="Background" Value="#2d1f1f"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Status}" FontSize="10">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#34d399"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                                    <Setter Property="Foreground" Value="#f87171"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <TextBlock x:Name="NoBookingsText" Text="Немає записаних клієнтів"
                                       Foreground="#374151" FontSize="12" HorizontalAlignment="Center"
                                       Margin="0,8,0,0" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="#131929" CornerRadius="0,0,16,16" Padding="24,0">
                <Button Content="Закрити" Height="40" Cursor="Hand" Click="Close_Click"
                        HorizontalAlignment="Right" Width="120">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#1a1f35"/>
                            <Setter Property="Foreground" Value="#9ca3af"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#252b45"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Border>
        </Grid>
    </Border>
</Window>