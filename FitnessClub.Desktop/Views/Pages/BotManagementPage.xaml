<Page x:Class="FitnessClub.Desktop.Views.Pages.BotManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="Керування ботом"
      Background="#0a0a0f">

    <Page.Resources>
        <!-- Стилі -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#12121a"/>
            <Setter Property="BorderBrush" Value="#1e1e2e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9ca3af"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1e1e2e"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActiveTabStyle" TargetType="Button" BasedOn="{StaticResource TabButtonStyle}">
            <Setter Property="Background" Value="#6366f1"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#6366f1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5558e3"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#3f3f46"/>
                    <Setter Property="Foreground" Value="#71717a"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1e1e2e"/>
            <Setter Property="Foreground" Value="#e5e7eb"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2d2d3a"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#1e1e2e"/>
            <Setter Property="Foreground" Value="#e5e7eb"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="#6366f1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChatMessageStyle" TargetType="Border">
            <Setter Property="Background" Value="#1e1e2e"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
    </Page.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="🤖 Керування Telegram ботом" 
                       FontSize="28" FontWeight="Bold" Foreground="White"/>
            <TextBlock x:Name="BotStatusText" 
                       Text="Статус: завантаження..." 
                       FontSize="14" Foreground="#9ca3af" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- Вкладки -->
        <Border Grid.Row="1" Background="#12121a" CornerRadius="10" Padding="4" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="TabStatsBtn" Content="📊 Статистика" 
                        Style="{StaticResource ActiveTabStyle}" Click="TabStats_Click"/>
                <Button x:Name="TabChatsBtn" Content="💬 Переписки" 
                        Style="{StaticResource TabButtonStyle}" Click="TabChats_Click"/>
                <Button x:Name="TabBroadcastBtn" Content="📢 Розсилка" 
                        Style="{StaticResource TabButtonStyle}" Click="TabBroadcast_Click"/>
                <Button x:Name="TabSettingsBtn" Content="⚙️ Налаштування" 
                        Style="{StaticResource TabButtonStyle}" Click="TabSettings_Click"/>
            </StackPanel>
        </Border>

        <!-- Контент вкладок -->
        <Grid Grid.Row="2">

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- ВКЛАДКА: СТАТИСТИКА -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <Grid x:Name="StatsTab" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Карточки статистики -->
                <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,20">
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="👥 Користувачів" Foreground="#9ca3af" FontSize="13"/>
                            <TextBlock x:Name="TotalUsersText" Text="0" 
                                       Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,8,0,0"/>
                            <TextBlock x:Name="NewUsersText" Text="+0 за тиждень" 
                                       Foreground="#22c55e" FontSize="12"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}" Margin="5,0">
                        <StackPanel>
                            <TextBlock Text="💬 Повідомлень сьогодні" Foreground="#9ca3af" FontSize="13"/>
                            <TextBlock x:Name="TodayMessagesText" Text="0" 
                                       Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,8,0,0"/>
                            <TextBlock x:Name="WeekMessagesText" Text="0 за тиждень" 
                                       Foreground="#60a5fa" FontSize="12"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}" Margin="5,0">
                        <StackPanel>
                            <TextBlock Text="🎫 QR запитів" Foreground="#9ca3af" FontSize="13"/>
                            <TextBlock x:Name="QrRequestsText" Text="0" 
                                       Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,8,0,0"/>
                            <TextBlock Text="за сьогодні" Foreground="#a78bfa" FontSize="12"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}" Margin="10,0,0,0">
                        <StackPanel>
                            <TextBlock Text="📩 Запитів підтримки" Foreground="#9ca3af" FontSize="13"/>
                            <TextBlock x:Name="SupportRequestsText" Text="0" 
                                       Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,8,0,0"/>
                            <TextBlock x:Name="UnreadSupportText" Text="0 непрочитаних" 
                                       Foreground="#f59e0b" FontSize="12"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Нижня частина -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="350"/>
                    </Grid.ColumnDefinitions>

                    <!-- Популярні команди -->
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="📈 Популярні команди" Foreground="White" 
                                       FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            <ListView x:Name="CommandStatsList" Grid.Row="1" 
                                      Background="Transparent" BorderThickness="0"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="60"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Command}" Foreground="#e5e7eb" FontSize="14"/>
                                            <Border Grid.Column="1" Background="#1e1e2e" CornerRadius="4" Height="8" Margin="10,0">
                                                <Border Background="#6366f1" CornerRadius="4" 
                                                        HorizontalAlignment="Left" Width="{Binding BarWidth}"/>
                                            </Border>
                                            <TextBlock Grid.Column="2" Text="{Binding Count}" 
                                                       Foreground="#9ca3af" FontSize="14" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <!-- Останні дії -->
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="10,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="🕐 Останні дії" Foreground="White" 
                                       FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                            <ListView x:Name="RecentActionsList" Grid.Row="1" 
                                      Background="Transparent" BorderThickness="0">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1a1a2e" CornerRadius="8" Padding="12,10" Margin="0,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Emoji}" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding UserName}" Foreground="#e5e7eb" FontSize="13"/>
                                                    <TextBlock Text="{Binding Action}" Foreground="#9ca3af" FontSize="12"/>
                                                    <TextBlock Text="{Binding TimeAgo}" Foreground="#6b7280" FontSize="11"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- ВКЛАДКА: ПЕРЕПИСКИ (ПІДТРИМКА) -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <Grid x:Name="ChatsTab" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Список чатів -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="💬 Запити підтримки" Foreground="White" 
                                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

                        <!-- Фільтр -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                            <Button x:Name="FilterAllBtn" Content="Всі" 
                                    Style="{StaticResource SecondaryButtonStyle}" 
                                    Click="FilterAll_Click" Margin="0,0,6,0"/>
                            <Button x:Name="FilterUnreadBtn" Content="Непрочитані" 
                                    Style="{StaticResource SecondaryButtonStyle}" 
                                    Click="FilterUnread_Click"/>
                        </StackPanel>

                        <ListView x:Name="ChatsList" Grid.Row="2" 
                                  Background="Transparent" BorderThickness="0"
                                  SelectionChanged="ChatsList_SelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding Background}" CornerRadius="10" 
                                            Padding="12,10" Margin="0,3" Cursor="Hand">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Background="#6366f1" CornerRadius="20" 
                                                    Width="36" Height="36">
                                                <TextBlock Text="{Binding Initials}" 
                                                           Foreground="White" FontSize="14" FontWeight="SemiBold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" Margin="10,0">
                                                <TextBlock Text="{Binding UserName}" Foreground="#e5e7eb" 
                                                           FontSize="14" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding LastMessage}" Foreground="#9ca3af" 
                                                           FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding TimeStr}" Foreground="#6b7280" 
                                                           FontSize="11" HorizontalAlignment="Right"/>
                                                <Border Background="#ef4444" CornerRadius="10" 
                                                        Padding="6,2" Margin="0,4,0,0"
                                                        Visibility="{Binding UnreadVisibility}" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding UnreadCount}" Foreground="White" 
                                                               FontSize="11" FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <!-- Чат -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="10,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Заголовок чату -->
                        <Border Grid.Row="0" BorderBrush="#1e1e2e" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,12">
                            <Grid>
                                <StackPanel x:Name="ChatHeaderPanel" Visibility="Collapsed">
                                    <TextBlock x:Name="ChatUserName" Text="" Foreground="White" 
                                               FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="ChatUserInfo" Text="" Foreground="#9ca3af" FontSize="12"/>
                                </StackPanel>
                                <TextBlock x:Name="NoChatSelected" Text="Оберіть чат зі списку" 
                                           Foreground="#6b7280" FontSize="14"/>
                            </Grid>
                        </Border>

                        <!-- Повідомлення -->
                        <ScrollViewer x:Name="MessagesScroll" Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="MessagesList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4">
                                            <Border Background="{Binding Background}" 
                                                    CornerRadius="12" Padding="14,10"
                                                    HorizontalAlignment="{Binding Alignment}"
                                                    MaxWidth="400">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Text}" Foreground="#e5e7eb" 
                                                               FontSize="14" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding TimeStr}" Foreground="#6b7280" 
                                                               FontSize="10" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Введення відповіді -->
                        <Grid x:Name="ReplyPanel" Grid.Row="2" Margin="0,12,0,0" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ReplyInput" Style="{StaticResource InputStyle}" 
                                     TextWrapping="Wrap" AcceptsReturn="True" MaxHeight="100"
                                     KeyDown="ReplyInput_KeyDown"/>
                            <Button Grid.Column="1" Content="📤 Надіслати" 
                                    Style="{StaticResource PrimaryButtonStyle}" 
                                    Margin="10,0,0,0" Click="SendReply_Click"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- ВКЛАДКА: РОЗСИЛКА -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <Grid x:Name="BroadcastTab" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="350"/>
                </Grid.ColumnDefinitions>

                <!-- Форма розсилки -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="📢 Масова розсилка" Foreground="White" 
                                   FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>

                        <!-- Кому -->
                        <TextBlock Text="Отримувачі" Foreground="#9ca3af" FontSize="13" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <RadioButton x:Name="BroadcastAll" Content="Всі користувачі" 
                                         Foreground="#e5e7eb" IsChecked="True" Margin="0,0,20,0"/>
                            <RadioButton x:Name="BroadcastActive" Content="З активним абонементом" 
                                         Foreground="#e5e7eb" Margin="0,0,20,0"/>
                            <RadioButton x:Name="BroadcastExpiring" Content="Абонемент закінчується" 
                                         Foreground="#e5e7eb"/>
                        </StackPanel>

                        <!-- Текст -->
                        <TextBlock Text="Текст повідомлення" Foreground="#9ca3af" FontSize="13" Margin="0,0,0,8"/>
                        <TextBox x:Name="BroadcastText" Style="{StaticResource InputStyle}" 
                                 Height="200" TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"/>

                        <!-- Прев'ю -->
                        <TextBlock Text="Прев'ю (MarkdownV2)" Foreground="#9ca3af" FontSize="13" Margin="0,20,0,8"/>
                        <Border Background="#1a1a2e" CornerRadius="8" Padding="16" MinHeight="80">
                            <TextBlock x:Name="BroadcastPreview" Text="" Foreground="#e5e7eb" 
                                       FontSize="14" TextWrapping="Wrap"/>
                        </Border>

                        <!-- Кнопки -->
                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                            <Button Content="📤 Надіслати розсилку" 
                                    Style="{StaticResource PrimaryButtonStyle}" 
                                    Click="SendBroadcast_Click"/>
                            <Button Content="👁 Прев'ю" 
                                    Style="{StaticResource SecondaryButtonStyle}" 
                                    Margin="10,0,0,0" Click="PreviewBroadcast_Click"/>
                        </StackPanel>

                        <!-- Прогрес -->
                        <Border x:Name="BroadcastProgress" Background="#1a1a2e" CornerRadius="8" 
                                Padding="16" Margin="0,20,0,0" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock x:Name="BroadcastProgressText" Text="Надсилання..." 
                                           Foreground="#e5e7eb" FontSize="14"/>
                                <ProgressBar x:Name="BroadcastProgressBar" Height="8" 
                                             Margin="0,10,0,0" Maximum="100" Value="0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Історія розсилок -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="10,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="📋 Історія розсилок" Foreground="White" 
                                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                        <ListView x:Name="BroadcastHistoryList" Grid.Row="1" 
                                  Background="Transparent" BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1a1a2e" CornerRadius="8" Padding="12" Margin="0,4">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Text}" Foreground="#e5e7eb" 
                                                       FontSize="13" TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <TextBlock Text="{Binding DateStr}" Foreground="#6b7280" FontSize="11"/>
                                                <TextBlock Text=" • " Foreground="#6b7280" FontSize="11"/>
                                                <TextBlock Text="{Binding SentCount}" Foreground="#22c55e" FontSize="11"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- ВКЛАДКА: НАЛАШТУВАННЯ -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <Grid x:Name="SettingsTab" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Налаштування бота -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="⚙️ Налаштування бота" Foreground="White" 
                                   FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>

                        <!-- Статус -->
                        <Border Background="#1a1a2e" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Статус бота" Foreground="#9ca3af" FontSize="13"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <Ellipse x:Name="BotStatusIndicator" Width="10" Height="10" 
                                                 Fill="#22c55e" Margin="0,0,8,0"/>
                                        <TextBlock x:Name="BotStatusLabel" Text="Онлайн" 
                                                   Foreground="#22c55e" FontSize="14" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </StackPanel>
                                <Button Grid.Column="1" x:Name="ToggleBotBtn" Content="⏸ Зупинити" 
                                        Style="{StaticResource SecondaryButtonStyle}" 
                                        Click="ToggleBot_Click"/>
                            </Grid>
                        </Border>

                        <!-- Інформація про бот -->
                        <TextBlock Text="Інформація" Foreground="#9ca3af" FontSize="13" Margin="0,0,0,8"/>
                        <Border Background="#1a1a2e" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Username:" Foreground="#6b7280" FontSize="13"/>
                                    <TextBlock x:Name="BotUsernameText" Text="@fitness_club_bot" 
                                               Foreground="#e5e7eb" FontSize="13" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Bot ID:" Foreground="#6b7280" FontSize="13"/>
                                    <TextBlock x:Name="BotIdText" Text="123456789" 
                                               Foreground="#e5e7eb" FontSize="13" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="Запущено:" Foreground="#6b7280" FontSize="13"/>
                                    <TextBlock x:Name="BotStartedText" Text="01.01.2024 10:00" 
                                               Foreground="#e5e7eb" FontSize="13" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Автоматичні повідомлення -->
                        <TextBlock Text="Автоматичні повідомлення" Foreground="#9ca3af" FontSize="13" Margin="0,0,0,8"/>
                        <Border Background="#1a1a2e" CornerRadius="8" Padding="16">
                            <StackPanel>
                                <CheckBox x:Name="NotifyExpiryCheck" Content="Нагадування про закінченн�� абонементу" 
                                          Foreground="#e5e7eb" IsChecked="True" Margin="0,0,0,10"/>
                                <CheckBox x:Name="NotifyNewScheduleCheck" Content="Сповіщення про новий розклад" 
                                          Foreground="#e5e7eb" IsChecked="True" Margin="0,0,0,10"/>
                                <CheckBox x:Name="NotifyPromosCheck" Content="Акції та знижки" 
                                          Foreground="#e5e7eb" IsChecked="False"/>
                            </StackPanel>
                        </Border>

                        <Button Content="💾 Зберегти налаштування" 
                                Style="{StaticResource PrimaryButtonStyle}" 
                                Margin="0,20,0,0" Click="SaveSettings_Click"/>
                    </StackPanel>
                </Border>

                <!-- Команди бота -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="📝 Команди бота" Foreground="White" 
                                   FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>

                        <TextBlock Text="Доступні команди для користувачів:" 
                                   Foreground="#9ca3af" FontSize="13" Margin="0,0,0,12"/>

                        <Border Background="#1a1a2e" CornerRadius="8" Padding="16">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <TextBlock Text="/start" Foreground="#6366f1" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="Початок роботи з ботом" Foreground="#9ca3af" 
                                               FontSize="12" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,0,0,12">
                                    <TextBlock Text="/qr" Foreground="#6366f1" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="Отримати QR-код" Foreground="#9ca3af" 
                                               FontSize="12" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,0,0,12">
                                    <TextBlock Text="/membership" Foreground="#6366f1" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="Інформація про абонемент" Foreground="#9ca3af" 
                                               FontSize="12" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,0,0,12">
                                    <TextBlock Text="/schedule" Foreground="#6366f1" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="Розклад занять" Foreground="#9ca3af" 
                                               FontSize="12" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Margin="0,0,0,12">
                                    <TextBlock Text="/support" Foreground="#6366f1" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="Зв'язок з адміністратором" Foreground="#9ca3af" 
                                               FontSize="12" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="/help" Foreground="#6366f1" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="Список команд" Foreground="#9ca3af" 
                                               FontSize="12" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Швидкі дії -->
                        <TextBlock Text="Швидкі дії" Foreground="#9ca3af" FontSize="13" Margin="0,20,0,12"/>
                        <StackPanel>
                            <Button Content="🔄 Перезапустити бота" 
                                    Style="{StaticResource SecondaryButtonStyle}" 
                                    Margin="0,0,0,8" Click="RestartBot_Click"/>
                            <Button Content="🧹 Очистити кеш" 
                                    Style="{StaticResource SecondaryButtonStyle}" 
                                    Margin="0,0,0,8" Click="ClearCache_Click"/>
                            <Button Content="📊 Експорт статистики" 
                                    Style="{StaticResource SecondaryButtonStyle}" 
                                    Click="ExportStats_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>