<Page x:Class="FitnessClub.Desktop.Views.Pages.AccessMonitorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:oxy="http://oxyplot.org/wpf">

    <Page.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#030712" Offset="0"/>
            <GradientStop Color="#0A0F1A" Offset="1"/>
        </LinearGradientBrush>
    </Page.Background>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══ -->
        <Grid Grid.Row="0" Margin="40,32,40,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Контроль доступу"
                               Foreground="White" FontSize="28" FontWeight="Bold"
                               FontFamily="Segoe UI Variable, Segoe UI">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#6366F1" BlurRadius="15" ShadowDepth="0" Opacity="0.3"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <Border Margin="14,8,0,0" VerticalAlignment="Top"
                            Background="#1000ff88" CornerRadius="10" Padding="10,4"
                            BorderBrush="#00ff88" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="#00ff88" Margin="0,0,6,0">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#00ff88" BlurRadius="6" ShadowDepth="0" Opacity="1"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock Text="LIVE" Foreground="#00ff88"
                                       FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <TextBlock Text="Сканування QR-кодів та моніторинг відвідувань"
                           Foreground="#4B5563" FontSize="13" Margin="0,6,0,0"/>
            </StackPanel>

            <!-- KPI праворуч -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Border CornerRadius="12" Padding="16,8" Margin="0,0,12,0" BorderThickness="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0d2a1f" Offset="0"/>
                            <GradientStop Color="#0d5540" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#2000ff88"/>
                    </Border.BorderBrush>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="👥 Сьогодні: " Foreground="#40a070" FontSize="13"/>
                        <TextBlock x:Name="TodayCountText" Text="0"
                                   Foreground="#00ff88" FontSize="13" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border CornerRadius="12" Padding="16,8" Margin="0,0,12,0" BorderThickness="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0a1e2e" Offset="0"/>
                            <GradientStop Color="#10405a" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#2000f5ff"/>
                    </Border.BorderBrush>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🏃 Зараз: " Foreground="#4090b0" FontSize="13"/>
                        <TextBlock x:Name="NowInClubText" Text="0"
                                   Foreground="#00f5ff" FontSize="13" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- ══ ВКЛАДКИ ══ -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="40,20,40,0">
            <Button x:Name="TabScanBtn" Click="TabScan_Click"
                    Padding="24,10" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="12" Padding="{TemplateBinding Padding}"
                                BorderThickness="1">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#6366F1"/>
                            </Border.BorderBrush>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#312e81" Offset="0"/>
                                    <GradientStop Color="#6366F1" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#6366F1" BlurRadius="14" ShadowDepth="0" Opacity="0.5"/>
                            </Border.Effect>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📷" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Сканування" Foreground="White"
                                           FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button x:Name="TabStatsBtn" Click="TabStats_Click"
                    Padding="24,10" Margin="12,0,0,0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" CornerRadius="12" Padding="{TemplateBinding Padding}"
                                BorderThickness="1">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#3a4560"/>
                            </Border.BorderBrush>
                            <Border.Background>
                                <SolidColorBrush Color="#10ffffff"/>
                            </Border.Background>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Моніторинг" Foreground="#8a9ab0"
                                           FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>

        <!-- ══ ВМІСТ ВКЛАДОК ══ -->
        <Grid Grid.Row="2" Margin="40,16,40,32">

            <!-- ══ ВКЛАДКА 1: СКАНУВАННЯ ══ -->
            <Grid x:Name="ScanTab">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="480"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ══ ЛІВА КОЛОНКА: Камера + кнопка ══ -->
                <Border Grid.Column="0" CornerRadius="24" BorderThickness="1"
                        Padding="24" Margin="0,0,20,0">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#15ffffff"/>
                    </Border.BorderBrush>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#12ffffff" Offset="0"/>
                            <GradientStop Color="#06ffffff" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="0" Opacity="0.5"/>
                    </Border.Effect>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="📷 Піднесіть QR-код до камери"
                                   Foreground="White" FontSize="16" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

                        <!-- Зображення камери -->
                        <Border CornerRadius="16" ClipToBounds="True"
                                HorizontalAlignment="Center" BorderThickness="2">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#00f5ff" Offset="0"/>
                                    <GradientStop Color="#bf5af2" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.Effect>
                                <DropShadowEffect Color="#00f5ff" BlurRadius="20" ShadowDepth="0" Opacity="0.4"/>
                            </Border.Effect>
                            <Image x:Name="CameraImage" Width="420" Height="315" Stretch="UniformToFill"/>
                        </Border>

                        <!-- Статус -->
                        <Border CornerRadius="12" Padding="14,10" Margin="0,20,0,0"
                                HorizontalAlignment="Center" Background="#10ffffff">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="ScanIndicator" Width="10" Height="10"
                                         Fill="#00ff88" Margin="0,0,10,0">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="#00ff88" BlurRadius="8" ShadowDepth="0" Opacity="1"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <TextBlock x:Name="ScanStatusText" Text="Очікування QR-коду..."
                                           Foreground="#8a9ab0" FontSize="13"/>
                            </StackPanel>
                        </Border>

                        <!-- ══ КНОПКА СКАНУВАТИ ЗНОВУ — завжди під камерою ══ -->
                        <Button x:Name="RescanButton"
                                Click="RescanButton_Click"
                                HorizontalAlignment="Center"
                                Margin="0,16,0,0"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bg" CornerRadius="14" Padding="32,12"
                                            BorderThickness="1">
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="#6366F1"/>
                                        </Border.BorderBrush>
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#1e1b4b" Offset="0"/>
                                                <GradientStop Color="#312e81" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.Effect>
                                            <DropShadowEffect Color="#6366F1" BlurRadius="16" ShadowDepth="0" Opacity="0.5"/>
                                        </Border.Effect>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🔄" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Сканувати знову" Foreground="White"
                                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Opacity" Value="0.8"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Bg" Property="Opacity" Value="0.6"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- ══ ПРАВА КОЛОНКА: Результат ══ -->
                <Border Grid.Column="1" CornerRadius="24" BorderThickness="1" Padding="48">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#15ffffff"/>
                    </Border.BorderBrush>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#10ffffff" Offset="0"/>
                            <GradientStop Color="#06ffffff" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="0" Opacity="0.5"/>
                    </Border.Effect>

                    <!-- ══ ПАНЕЛІ РЕЗУЛЬТАТУ ══ -->
                    <Grid>
                        <!-- IDLE -->
                        <StackPanel x:Name="IdlePanel"
                                    VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="🎯" FontSize="80" HorizontalAlignment="Center" Margin="0,0,0,24"/>
                            <TextBlock Text="Готовий до сканування" Foreground="White"
                                       FontSize="24" FontWeight="Bold"
                                       HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock Text="Піднесіть QR-код з телефону до камери"
                                       Foreground="#5a6580" FontSize="14"
                                       HorizontalAlignment="Center" TextAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- ДОЗВОЛЕНО -->
                        <StackPanel x:Name="AllowedPanel" Visibility="Collapsed"
                                    VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="✅" FontSize="90" HorizontalAlignment="Center" Margin="0,0,0,20">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#00ff88" BlurRadius="30" ShadowDepth="0" Opacity="0.8"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="ВХІД ДОЗВОЛЕНО" Foreground="#00ff88"
                                       FontSize="36" FontWeight="Bold"
                                       HorizontalAlignment="Center" Margin="0,0,0,28">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#00ff88" BlurRadius="20" ShadowDepth="0" Opacity="0.9"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <Border Width="90" Height="90" CornerRadius="45"
                                    HorizontalAlignment="Center" Margin="0,0,0,16">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#00f5ff" Offset="0"/>
                                        <GradientStop Color="#bf5af2" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock x:Name="AllowedInitials" Text="АБ" Foreground="White"
                                           FontSize="28" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="AllowedName" Text="" Foreground="White"
                                       FontSize="28" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock x:Name="AllowedMembership" Text="" Foreground="#40a070"
                                       FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,24"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                                <Border CornerRadius="10" Padding="20,10" Margin="0,0,12,0" Background="#10ffffff">
                                    <StackPanel>
                                        <TextBlock Text="Діє до" Foreground="#5a7560"
                                                   FontSize="12" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="AllowedExpiry" Text="" Foreground="#00ff88"
                                                   FontSize="16" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border CornerRadius="10" Padding="20,10" Background="#10ffffff">
                                    <StackPanel>
                                        <TextBlock Text="Залишилось" Foreground="#5a7560"
                                                   FontSize="12" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="AllowedDaysLeft" Text="" Foreground="#00f5ff"
                                                   FontSize="16" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <TextBlock x:Name="AllowedSubMsg" Text=""
                                       FontSize="14" FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- ЗАБОРОНЕНО -->
                        <StackPanel x:Name="DeniedPanel" Visibility="Collapsed"
                                    VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="❌" FontSize="90" HorizontalAlignment="Center" Margin="0,0,0,20">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#ff453a" BlurRadius="30" ShadowDepth="0" Opacity="0.8"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="ДОСТУП ЗАБОРОНЕНО" Foreground="#ff453a"
                                       FontSize="34" FontWeight="Bold"
                                       HorizontalAlignment="Center" Margin="0,0,0,28">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#ff453a" BlurRadius="20" ShadowDepth="0" Opacity="0.9"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <Border Width="90" Height="90" CornerRadius="45"
                                    HorizontalAlignment="Center" Margin="0,0,0,16" Background="#2e0a0a">
                                <TextBlock x:Name="DeniedInitials" Text="?" Foreground="#ff453a"
                                           FontSize="32" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="DeniedName" Text="" Foreground="White"
                                       FontSize="26" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" Margin="0,0,0,16"/>
                            <Border CornerRadius="14" Padding="24,16" HorizontalAlignment="Center"
                                    MinWidth="300" BorderThickness="1" Background="#15ffffff">
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#20ff453a"/>
                                </Border.BorderBrush>
                                <TextBlock x:Name="DeniedMessage" Text="" Foreground="#ff7070"
                                           FontSize="16" TextAlignment="Center" TextWrapping="Wrap"/>
                            </Border>
                            <TextBlock Text="Зверніться до адміністратора" Foreground="#5a4040"
                                       FontSize="13" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ══ ВКЛАДКА 2: МОНІТОРИНГ ══ -->
            <Grid x:Name="StatsTab" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="380"/>
                </Grid.ColumnDefinitions>

                <!-- KPI рядок зверху -->
                <Grid Grid.Column="0" Grid.ColumnSpan="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <UniformGrid Columns="3" Margin="0,0,0,16">
                        <Border Margin="0,0,12,0" CornerRadius="14" BorderThickness="1" Padding="16">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1a0d2e" Offset="0"/>
                                    <GradientStop Color="#3d2266" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#20bf5af2"/>
                            </Border.BorderBrush>
                            <StackPanel>
                                <TextBlock Text="За тиждень" Foreground="#9070c0" FontSize="12"/>
                                <TextBlock x:Name="WeekCountText" Text="0" Foreground="#bf5af2"
                                           FontSize="28" FontWeight="Bold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,12,0" CornerRadius="14" BorderThickness="1" Padding="16">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#2e1a0a" Offset="0"/>
                                    <GradientStop Color="#664015" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#20ff9f0a"/>
                            </Border.BorderBrush>
                            <StackPanel>
                                <TextBlock Text="За місяць" Foreground="#c08040" FontSize="12"/>
                                <TextBlock x:Name="MonthCountText" Text="0" Foreground="#ff9f0a"
                                           FontSize="28" FontWeight="Bold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="14" BorderThickness="1" Padding="16">
                            <Border.Background>
                                <SolidColorBrush Color="#10ffffff"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#15ffffff"/>
                            </Border.BorderBrush>
                            <StackPanel>
                                <TextBlock x:Name="LastUpdateText" Text="оновлення..."
                                           Foreground="#4a6070" FontSize="11"/>
                                <TextBlock Text="Останнє оновлення" Foreground="#3a4560" FontSize="12"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Графік + список -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="380"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" CornerRadius="20" BorderThickness="1" Padding="24">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#15ffffff"/>
                            </Border.BorderBrush>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#12ffffff" Offset="0"/>
                                    <GradientStop Color="#08ffffff" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="4" Opacity="0.3"/>
                            </Border.Effect>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <Border Width="4" Height="18" CornerRadius="2" Margin="0,0,12,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#6366F1" Offset="0"/>
                                                <GradientStop Color="#00f5ff" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <TextBlock Text="Відвідування по годинах (сьогодні)"
                                               Foreground="White" FontSize="15" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <oxy:PlotView x:Name="HourlyChart" Height="240" Background="Transparent"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" CornerRadius="20" BorderThickness="1" Padding="24">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#15ffffff"/>
                            </Border.BorderBrush>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#12ffffff" Offset="0"/>
                                    <GradientStop Color="#08ffffff" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="4" Opacity="0.3"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <Border Width="4" Height="18" CornerRadius="2" Margin="0,0,12,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#00ff88" Offset="0"/>
                                                <GradientStop Color="#00f5ff" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <TextBlock Text="Останні входи" Foreground="White"
                                               FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="RecentVisitsList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#10ffffff" BorderThickness="0,0,0,1" Padding="0,12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Width="38" Height="38" CornerRadius="19" Margin="0,0,12,0">
                                                            <Border.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                    <GradientStop Color="#00f5ff" Offset="0"/>
                                                                    <GradientStop Color="#bf5af2" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                            <TextBlock Text="{Binding Initials}" Foreground="White"
                                                                       FontSize="13" FontWeight="Bold"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                        </Border>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding ClientName}"
                                                                       Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding MembershipType}"
                                                                       Foreground="#5a6580" FontSize="11"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2" Text="{Binding TimeStr}"
                                                                   Foreground="#00f5ff" FontSize="13" FontWeight="Bold"
                                                                   VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
