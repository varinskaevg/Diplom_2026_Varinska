<Page x:Class="FitnessClub.Desktop.Views.Pages.MembershipsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#05070F">

    <Page.Resources>
        <LinearGradientBrush x:Key="AuroraBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF6C63FF" Offset="0"/>
            <GradientStop Color="#FF00D9FF" Offset="0.5"/>
            <GradientStop Color="#FF00FF94" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="CutCornerCard" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#12FFFFFF" Offset="0"/>
                        <GradientStop Color="#08FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#306C63FF" Offset="0"/>
                        <GradientStop Color="#1500D9FF" Offset="0.5"/>
                        <GradientStop Color="#3000FF94" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4,20,4,20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#6C63FF" BlurRadius="30" ShadowDepth="0" Opacity="0.15"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NeonPillButton" TargetType="Button">
            <Setter Property="Height" Value="50"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MainBorder" CornerRadius="25" Padding="32,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#6C63FF" Offset="0"/>
                                    <GradientStop Color="#00D9FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#6C63FF" BlurRadius="25" ShadowDepth="0" Opacity="0.5"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00D9FF" BlurRadius="40" ShadowDepth="0" Opacity="0.8"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ТАБ — для верхніх табів і для фільтрів -->
        <Style x:Key="CyberTab" TargetType="Button">
            <Setter Property="Height" Value="52"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MainBorder" CornerRadius="2,12,2,12" Padding="26,0"
                                Background="#0CFFFFFF" BorderThickness="1" BorderBrush="#25FFFFFF">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#20FFFFFF"/>
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#406C63FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ФІЛЬТР-ТАБ — RadioButton у вигляді CyberTab -->
        <Style x:Key="FilterTab" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="RadioBorder" CornerRadius="2,12,2,12" Padding="22,0" Height="52"
                                Background="#0CFFFFFF" BorderThickness="1" BorderBrush="#25FFFFFF">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RadioBorder" Property="Background" Value="#20FFFFFF"/>
                                <Setter TargetName="RadioBorder" Property="BorderBrush" Value="#406C63FF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RadioBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#306C63FF" Offset="0"/>
                                            <GradientStop Color="#2000D9FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="RadioBorder" Property="BorderBrush">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#806C63FF" Offset="0"/>
                                            <GradientStop Color="#8000D9FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="#00D9FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostIcon" TargetType="Button">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MainBorder" CornerRadius="10"
                                Background="Transparent" BorderThickness="1" BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#156C63FF"/>
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#306C63FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostIconDanger" TargetType="Button">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MainBorder" CornerRadius="10"
                                Background="Transparent" BorderThickness="1" BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#20EF4444"/>
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#40EF4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MembershipCard" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="CardBorder" CornerRadius="4,18,4,18" Padding="0"
                                Background="#0AFFFFFF" BorderThickness="1" BorderBrush="#25FFFFFF">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="#12FFFFFF"/>
                                <Setter TargetName="CardBorder" Property="BorderBrush">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#306C63FF" Offset="0"/>
                                            <GradientStop Color="#3000D9FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="CardBorder" Property="BorderBrush">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#506C63FF" Offset="0"/>
                                            <GradientStop Color="#5000D9FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TypeCard" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,16,16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="CardBorder" CornerRadius="4,20,4,20" Width="300"
                                Background="#0CFFFFFF" BorderThickness="1" BorderBrush="#25FFFFFF">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#6C63FF" BlurRadius="30" ShadowDepth="0" Opacity="0.3"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="CardBorder" Property="BorderBrush">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#406C63FF" Offset="0"/>
                                            <GradientStop Color="#4000D9FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InvisibleScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#05070F" Offset="0"/>
                <GradientStop Color="#0A0D1A" Offset="0.5"/>
                <GradientStop Color="#080B15" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Canvas IsHitTestVisible="False">
            <Ellipse Canvas.Left="-100" Canvas.Top="-50" Width="500" Height="500">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#206C63FF" Offset="0"/>
                        <GradientStop Color="#006C63FF" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Canvas.Left="700" Canvas.Top="100" Width="450" Height="450">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#1800D9FF" Offset="0"/>
                        <GradientStop Color="#0000D9FF" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Canvas.Left="300" Canvas.Top="450" Width="400" Height="400">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#1200FF94" Offset="0"/>
                        <GradientStop Color="#0000FF94" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
        </Canvas>

        <Canvas IsHitTestVisible="False" Opacity="0.15">
            <Line X1="0" Y1="150" X2="2000" Y2="150" Stroke="#6C63FF" StrokeThickness="1" StrokeDashArray="20,10"/>
            <Line X1="0" Y1="400" X2="2000" Y2="400" Stroke="#00D9FF" StrokeThickness="1" StrokeDashArray="15,8"/>
        </Canvas>

        <Grid Margin="40,32,40,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0" Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="M E M B E R S H I P   C O N T R O L"
                               Foreground="#90FFFFFF" FontFamily="Segoe UI" FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Абонементи" FontFamily="Segoe UI" FontSize="44" FontWeight="Bold">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FFFFFF" Offset="0"/>
                                    <GradientStop Color="#00D9FF" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <Border CornerRadius="16" Padding="14,7" Margin="16,8,0,0" VerticalAlignment="Center"
                                Background="#106C63FF" BorderThickness="1" BorderBrush="#506C63FF">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,8,0" Fill="#6C63FF">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="#6C63FF" BlurRadius="10" ShadowDepth="0" Opacity="1"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <TextBlock Text="SYNC" Foreground="#B0A0FF" FontFamily="Segoe UI" FontSize="13" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border CornerRadius="14" Padding="4" Background="#08FFFFFF" BorderThickness="1" BorderBrush="#25FFFFFF" Margin="0,0,20,0">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="TabActiveBtn" Style="{StaticResource CyberTab}" Click="TabActive_Click" Margin="0,0,4,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4CB;" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Активні" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="TabTypesBtn" Style="{StaticResource CyberTab}" Click="TabTypes_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F3F7;" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Типи"/>
                                    <Border CornerRadius="8" Padding="10,3" Margin="10,0,0,0" Background="#206C63FF">
                                        <TextBlock x:Name="TypesCountText" Text="0" Foreground="#B0A0FF" FontSize="13" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                    <Button Style="{StaticResource NeonPillButton}" Click="SellMembership_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+" Foreground="White" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Продати абонемент" Foreground="White" FontFamily="Segoe UI" FontSize="15" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- СТАТИСТИКА + ФІЛЬТРИ -->
            <Grid Grid.Row="1" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Style="{StaticResource CutCornerCard}" Padding="22,18" Margin="0,0,12,0" MinWidth="160">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="АКТИВНИХ" Foreground="#C0FFFFFF" FontFamily="Segoe UI" FontSize="12" FontWeight="Bold"/>
                                <TextBlock x:Name="StatActive" Text="—" Foreground="#00FF94"
                                           FontFamily="Segoe UI" FontSize="38" FontWeight="Bold" Margin="0,4,0,0">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#00FF94" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </StackPanel>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Width="36" Height="36"
                                    CornerRadius="2,10,2,10" Background="#1500FF94" Margin="0,0,-20,0">
                                <TextBlock Text="&#x2713;" FontSize="16" Foreground="#00FF94"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CutCornerCard}" Padding="22,18" Margin="0,0,12,0" MinWidth="155">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="ЗАМОРОЖЕНО" Foreground="#C0FFFFFF" FontFamily="Segoe UI" FontSize="12" FontWeight="Bold"/>
                                <TextBlock x:Name="StatFrozen" Text="—" Foreground="#00D9FF"
                                           FontFamily="Segoe UI" FontSize="38" FontWeight="Bold" Margin="0,4,0,0">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#00D9FF" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </StackPanel>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Width="36" Height="36"
                                    CornerRadius="2,10,2,10" Background="#1500D9FF" Margin="0,0,-21,0">
                                <TextBlock Text="&#x2744;" FontSize="16" Foreground="#00D9FF"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CutCornerCard}" Padding="22,18" Margin="0,0,12,0" MinWidth="165">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="ЗАКІНЧУЄТЬСЯ" Foreground="#C0FFFFFF" FontFamily="Segoe UI" FontSize="12" FontWeight="Bold"/>
                                <TextBlock x:Name="StatExpiring" Text="—" Foreground="#F59E0B"
                                           FontFamily="Segoe UI" FontSize="38" FontWeight="Bold" Margin="0,4,0,0">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#F59E0B" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </StackPanel>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Width="36" Height="36"
                                    CornerRadius="2,10,2,10" Background="#15F59E0B" Margin="0,0,-21,0">
                                <TextBlock Text="&#x26A0;" FontSize="16" Foreground="#F59E0B"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CutCornerCard}" Padding="22,18" MinWidth="195">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="ДОХІД МІСЯЦЯ" Foreground="#C0FFFFFF" FontFamily="Segoe UI" FontSize="12" FontWeight="Bold"/>
                                <TextBlock x:Name="StatRevenueAmount" Text="—" Foreground="#6C63FF"
                                           FontFamily="Segoe UI" FontSize="34" FontWeight="Bold" Margin="0,4,0,0">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#6C63FF" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock Text="грн" Foreground="#90A0FF" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Width="36" Height="36"
                                    CornerRadius="2,10,2,10" Background="#156C63FF" Margin="0,0,-14,0">
                                <TextBlock Text="&#x20B4;" FontSize="16" Foreground="#B0A0FF" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ФІЛЬТРИ у стилі CyberTab -->
                <Border Grid.Column="1" CornerRadius="14" Padding="4" Background="#08FFFFFF" BorderThickness="1" BorderBrush="#25FFFFFF">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="FilterAll" Style="{StaticResource FilterTab}" IsChecked="True"
                                     GroupName="StatusFilter" Checked="Filter_Changed" Content="Всі" Margin="0,0,4,0"/>
                        <RadioButton x:Name="FilterActive" Style="{StaticResource FilterTab}"
                                     GroupName="StatusFilter" Checked="Filter_Changed" Content="Активні" Margin="0,0,4,0"/>
                        <RadioButton x:Name="FilterFrozen" Style="{StaticResource FilterTab}"
                                     GroupName="StatusFilter" Checked="Filter_Changed" Content="Заморожені" Margin="0,0,4,0"/>
                        <RadioButton x:Name="FilterExpired" Style="{StaticResource FilterTab}"
                                     GroupName="StatusFilter" Checked="Filter_Changed" Content="Прострочені" Margin="0,0,4,0"/>
                        <RadioButton x:Name="FilterCancelled" Style="{StaticResource FilterTab}"
                                     GroupName="StatusFilter" Checked="Filter_Changed" Content="Скасовані"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- PANEL: Active Memberships -->
            <Border x:Name="ActivePanel" Grid.Row="2" Style="{StaticResource CutCornerCard}" CornerRadius="4,24,4,24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="#20FFFFFF" BorderThickness="0,0,0,1" Padding="28,22">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="135"/>
                                <ColumnDefinition Width="135"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="КЛІЄНТ / ТИП" Foreground="#D0FFFFFF" FontFamily="Segoe UI" FontSize="13" FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Text="ПЕРІОД" Foreground="#D0FFFFFF" FontFamily="Segoe UI" FontSize="13" FontWeight="Bold"/>
                            <TextBlock Grid.Column="2" Text="СТАТУС" Foreground="#D0FFFFFF" FontFamily="Segoe UI" FontSize="13" FontWeight="Bold"/>
                            <TextBlock Grid.Column="3" Text="ЗАЛИШИЛОСЬ" Foreground="#D0FFFFFF" FontFamily="Segoe UI" FontSize="13" FontWeight="Bold"/>
                            <TextBlock Grid.Column="4" Text="ДІЇ" Foreground="#D0FFFFFF" FontFamily="Segoe UI" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <ListView x:Name="MembershipsList" Grid.Row="1"
                              Background="Transparent" BorderThickness="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Hidden"
                              Padding="12">
                        <ListView.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource InvisibleScrollBar}"/>
                        </ListView.Resources>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem" BasedOn="{StaticResource MembershipCard}"/>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="16,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="135"/>
                                        <ColumnDefinition Width="135"/>
                                        <ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Width="52" Height="52" CornerRadius="4,14,4,14" Margin="0,0,14,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#6C63FF" Offset="0"/>
                                                    <GradientStop Color="#00D9FF" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Border.Effect>
                                                <DropShadowEffect Color="#6C63FF" BlurRadius="15" ShadowDepth="0" Opacity="0.4"/>
                                            </Border.Effect>
                                            <TextBlock Text="{Binding Initials}" Foreground="White"
                                                       FontFamily="Segoe UI" FontSize="16" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ClientName}" Foreground="#FFFFFF"
                                                       FontFamily="Segoe UI" FontSize="15" FontWeight="SemiBold"/>
                                            <Border CornerRadius="6" Padding="10,4" Margin="0,5,0,0" HorizontalAlignment="Left"
                                                    Background="#106C63FF" BorderThickness="1" BorderBrush="#356C63FF">
                                                <TextBlock Text="{Binding MembershipTypeName}" Foreground="#B0A0FF"
                                                           FontFamily="Segoe UI" FontSize="13"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Foreground="#D0FFFFFF" FontFamily="Segoe UI" FontSize="14">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0} — {1}">
                                                    <Binding Path="StartDate"/>
                                                    <Binding Path="EndDate"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>

                                    <Border Grid.Column="2" CornerRadius="8" Padding="14,7"
                                            VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#1500FF94"/>
                                                <Setter Property="BorderBrush" Value="#3000FF94"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Frozen">
                                                        <Setter Property="Background" Value="#1500D9FF"/>
                                                        <Setter Property="BorderBrush" Value="#3000D9FF"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Expired">
                                                        <Setter Property="Background" Value="#15EF4444"/>
                                                        <Setter Property="BorderBrush" Value="#30EF4444"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                        <Setter Property="Background" Value="#15888888"/>
                                                        <Setter Property="BorderBrush" Value="#30888888"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding StatusUa}" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#00FF94"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Frozen">
                                                            <Setter Property="Foreground" Value="#00D9FF"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Expired">
                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                            <Setter Property="Foreground" Value="#AAAAAA"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DaysLeftText}" Foreground="#FFFFFF"
                                                   FontFamily="Segoe UI" FontSize="15" FontWeight="SemiBold"/>
                                        <Border CornerRadius="2" Height="5" Width="90" Background="#25FFFFFF" Margin="0,7,0,0">
                                            <Border CornerRadius="2" Height="5" HorizontalAlignment="Left"
                                                    Width="{Binding ProgressWidth}">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#6C63FF" Offset="0"/>
                                                        <GradientStop Color="#00D9FF" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Style="{StaticResource GhostIcon}" ToolTip="Редагувати"
                                                Tag="{Binding Id}" Click="Edit_Click">
                                            <TextBlock Text="&#x270E;" FontSize="16" Foreground="#B0A0FF"/>
                                        </Button>
                                        <Button Style="{StaticResource GhostIcon}" ToolTip="Заморозити/Розморозити"
                                                Tag="{Binding Id}" Click="FreezeUnfreeze_Click" Margin="4,0">
                                            <TextBlock Text="&#x2744;" FontSize="16" Foreground="#00D9FF"/>
                                        </Button>
                                        <Button Style="{StaticResource GhostIcon}" ToolTip="Повернення коштів"
                                                Tag="{Binding Id}" Click="Refund_Click"
                                                Visibility="{Binding RefundVisible}">
                                            <TextBlock Text="&#x21A9;" FontSize="16" Foreground="#F59E0B"/>
                                        </Button>
                                        <Button Style="{StaticResource GhostIconDanger}" ToolTip="Видалити"
                                                Tag="{Binding Id}" Click="Delete_Click"
                                                Visibility="{Binding DeleteVisible}">
                                            <TextBlock Text="&#x1F5D1;" FontSize="16" Foreground="#EF4444"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- PANEL: Membership Types -->
            <Border x:Name="TypesPanel" Grid.Row="2" Style="{StaticResource CutCornerCard}" CornerRadius="4,24,4,24"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="#20FFFFFF" BorderThickness="0,0,0,1" Padding="28,22">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Типи абонементів" Foreground="#FFFFFF" FontFamily="Segoe UI" FontSize="20" FontWeight="SemiBold"/>
                                <TextBlock Text="Доступні пакети послуг" Foreground="#C0FFFFFF" FontFamily="Segoe UI" FontSize="14" Margin="0,5,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Border CornerRadius="8" Padding="14,7" Margin="0,0,12,0" Background="#106C63FF" BorderThickness="1" BorderBrush="#306C63FF">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Мін: " Foreground="#C0FFFFFF" FontFamily="Segoe UI" FontSize="14"/>
                                        <TextBlock x:Name="CheapestText" Text="—" Foreground="#00FF94" FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                                <Border CornerRadius="8" Padding="14,7" Background="#106C63FF" BorderThickness="1" BorderBrush="#306C63FF">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Макс: " Foreground="#C0FFFFFF" FontFamily="Segoe UI" FontSize="14"/>
                                        <TextBlock x:Name="MostExpensiveText" Text="—" Foreground="#B0A0FF" FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ListView x:Name="TypesList" Grid.Row="1"
                              Background="Transparent" BorderThickness="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Hidden"
                              Padding="20">
                        <ListView.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource InvisibleScrollBar}"/>
                        </ListView.Resources>
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem" BasedOn="{StaticResource TypeCard}"/>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" CornerRadius="4,20,0,0" Padding="22,18">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#156C63FF" Offset="0"/>
                                                <GradientStop Color="#1000D9FF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Grid>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" Foreground="#FFFFFF"
                                                           FontFamily="Segoe UI" FontSize="18" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding DurationText}" Foreground="#C0FFFFFF"
                                                           FontFamily="Segoe UI" FontSize="14" Margin="0,5,0,0"/>
                                            </StackPanel>
                                            <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                                    CornerRadius="8" Padding="12,5" Background="#206C63FF">
                                                <TextBlock Text="{Binding PopularityText}" Foreground="#B0A0FF"
                                                           FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"/>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="1" Padding="22,18" Background="Transparent">
                                        <StackPanel>
                                            <TextBlock Text="ЦІНА" Foreground="#C0FFFFFF" FontFamily="Segoe UI" FontSize="12" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding PriceText}" FontFamily="Segoe UI" FontSize="36" FontWeight="Bold" Margin="0,5,0,0">
                                                <TextBlock.Foreground>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#00FF94" Offset="0"/>
                                                        <GradientStop Color="#00D9FF" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </TextBlock.Foreground>
                                                <TextBlock.Effect>
                                                    <DropShadowEffect Color="#00FF94" BlurRadius="15" ShadowDepth="0" Opacity="0.4"/>
                                                </TextBlock.Effect>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="2" Padding="22,0,22,18">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <TextBlock Text="{Binding GymIcon}" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <TextBlock Text="Тренажерний зал" Foreground="#D0FFFFFF" FontFamily="Segoe UI" FontSize="14"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <TextBlock Text="{Binding PoolIcon}" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <TextBlock Text="Басейн" Foreground="#D0FFFFFF" FontFamily="Segoe UI" FontSize="14"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding ClassesIcon}" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <TextBlock Text="Групові заняття" Foreground="#D0FFFFFF" FontFamily="Segoe UI" FontSize="14"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="3" Padding="18,0,18,18">
                                        <Button Style="{StaticResource NeonPillButton}" Height="44" Click="SellType_Click" Tag="{Binding Id}">
                                            <TextBlock Text="Продати" Foreground="White" FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"/>
                                        </Button>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Page>
