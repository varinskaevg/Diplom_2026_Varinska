<Page x:Class="FitnessClub.Desktop.Views.Pages.ClientsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#08090D">

    <Page.Resources>
        <!-- ═══════════════════════════════════════════════════════════════
                              GLASSMORPHISM КАРТКА
             ═══════════════════════════════════════════════════════════════ -->
        <Style x:Key="GlassCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#40FFFFFF" Offset="0"/>
                        <GradientStop Color="#10FFFFFF" Offset="0.5"/>
                        <GradientStop Color="#20FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#18FFFFFF" Offset="0"/>
                        <GradientStop Color="#08FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="0" Opacity="0.5"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════════
                              НЕОНОВА КНОПКА
             ═══════════════════════════════════════════════════════════════ -->
        <Style x:Key="NeonButton" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#0A1A10"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MainBorder" CornerRadius="14" Padding="24,0"
                                BorderThickness="1" BorderBrush="#30FFFFFF">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#00FF94" Offset="0"/>
                                    <GradientStop Color="#00D67B" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#00FF94" BlurRadius="25" ShadowDepth="0" Opacity="0.6"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00FF94" BlurRadius="45" ShadowDepth="0" Opacity="1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="MainBorder" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════════
                              GHOST КНОПКА
             ═══════════════════════════════════════════════════════════════ -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MainBorder" CornerRadius="10"
                                Background="#15FFFFFF" BorderThickness="1" BorderBrush="#20FFFFFF">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#25FFFFFF"/>
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#40FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#30FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════════
                              ICON BUTTON (View/Edit/Delete)
             ═══════════════════════════════════════════════════════════════ -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MainBorder" CornerRadius="10"
                                Background="#10FFFFFF" BorderThickness="1" BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#204A8AFF"/>
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#404A8AFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButtonDanger" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MainBorder" CornerRadius="10"
                                Background="#10FFFFFF" BorderThickness="1" BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#20EF4444"/>
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#40EF4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════════
                              СТИЛЬ РЯДКА ТАБЛИЦІ
             ═══════════════════════════════════════════════════════════════ -->
        <Style x:Key="TableRow" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="24,16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="RowBorder" Background="Transparent"
                                BorderBrush="#10FFFFFF" BorderThickness="0,0,0,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="#08FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="#10FFFFFF"/>
                                <Setter TargetName="RowBorder" Property="BorderBrush" Value="#204A8AFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════════
                              ПОШУКОВИЙ TEXTBOX
             ═══════════════════════════════════════════════════════════════ -->
        <Style x:Key="SearchTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#00FF94"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                            <TextBlock x:Name="Placeholder" Text="Пошук клієнтів за ім'ям, email або телефоном..."
                                       Foreground="#50FFFFFF" FontFamily="Segoe UI" FontSize="14"
                                       VerticalAlignment="Center" IsHitTestVisible="False"
                                       Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Text" Value=""/>
                                    <Condition Property="IsFocused" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <!-- ═══════════════════════════════════════════════════════════════════════
                                   ГОЛОВНИЙ КОНТЕЙНЕР
         ═══════════════════════════════════════════════════════════════════════ -->
    <Grid>
        <!-- Космічний фон з градієнтами -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#08090D" Offset="0"/>
                <GradientStop Color="#0A0E18" Offset="0.5"/>
                <GradientStop Color="#0D1020" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Декоративні світлові плями -->
        <Canvas IsHitTestVisible="False">
            <Ellipse Canvas.Left="-150" Canvas.Top="100" Width="500" Height="500">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#184A8AFF" Offset="0"/>
                        <GradientStop Color="#004A8AFF" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Canvas.Left="900" Canvas.Top="-100" Width="400" Height="400">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#1500FF94" Offset="0"/>
                        <GradientStop Color="#0000FF94" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Canvas.Left="600" Canvas.Top="500" Width="350" Height="350">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#10C084FC" Offset="0"/>
                        <GradientStop Color="#00C084FC" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
        </Canvas>

        <Grid Margin="40,32,40,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════════════════════════════════
                                         HEADER
                 ══════════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="0" Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Управління клієнтами"
                               Foreground="#60FFFFFF" FontFamily="Segoe UI" FontSize="14" FontWeight="Light"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Клієнти" FontFamily="Segoe UI" FontSize="38" FontWeight="Bold">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FFFFFF" Offset="0"/>
                                    <GradientStop Color="#A0FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <!-- Кількість клієнтів -->
                        <Border CornerRadius="20" Padding="14,6" Margin="16,6,0,0" VerticalAlignment="Center"
                                BorderThickness="1" BorderBrush="#304A8AFF">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#154A8AFF" Offset="0"/>
                                    <GradientStop Color="#084A8AFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="TotalClientsCount" Text="1,247"
                                           Foreground="#4A8AFF" FontFamily="Segoe UI" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Text=" клієнтів" Foreground="#704A8AFF" FontFamily="Segoe UI" FontSize="13"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Експорт -->
                    <Button Style="{StaticResource GhostButton}" Margin="0,0,12,0" ToolTip="Експорт">
                        <TextBlock Text="&#x2B07;" Foreground="#70FFFFFF" FontSize="14"/>
                    </Button>
                    <!-- Фільтри -->
                    <Button Style="{StaticResource GhostButton}" Margin="0,0,16,0" ToolTip="Фільтри">
                        <TextBlock Text="&#x2630;" Foreground="#70FFFFFF" FontSize="14"/>
                    </Button>
                    <!-- Додати клієнта -->
                    <Button Style="{StaticResource NeonButton}" Click="AddClient_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+" Foreground="#0A1A10" FontSize="21" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Новий клієнт" Foreground="#0A1A10" FontFamily="Segoe UI" FontSize="21" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ══════════════════════════════════════════════════════════════
                                     СТАТИСТИКА КАРТКИ
                 ══════════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="1" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Всього -->
                <Border Grid.Column="0" Style="{StaticResource GlassCard}" Margin="0,0,12,0" Padding="20">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#154A8AFF" Offset="0"/>
                            <GradientStop Color="#08283870" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Всього клієнтів" Foreground="#60FFFFFF" FontFamily="Segoe UI" FontSize="12"/>
                            <TextBlock x:Name="StatTotalClients" Text="1,247" Foreground="#4A8AFF" 
                                       FontFamily="Segoe UI" FontSize="49" FontWeight="Bold" Margin="0,8,0,0">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#4A8AFF" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </StackPanel>
                        <Border HorizontalAlignment="Right" VerticalAlignment="Top" Width="40" Height="40" CornerRadius="12"
                                Background="#204A8AFF">
                            <TextBlock Text="&#x1F465;" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Активні абонементи -->
                <Border Grid.Column="1" Style="{StaticResource GlassCard}" Margin="0,0,12,0" Padding="20">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1500FF94" Offset="0"/>
                            <GradientStop Color="#08004830" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="З абонементом" Foreground="#60FFFFFF" FontFamily="Segoe UI" FontSize="12"/>
                            <TextBlock x:Name="StatActiveMembers" Text="892" Foreground="#00FF94" 
                                       FontFamily="Segoe UI" FontSize="49" FontWeight="Bold" Margin="0,8,0,0">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#00FF94" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </StackPanel>
                        <Border HorizontalAlignment="Right" VerticalAlignment="Top" Width="40" Height="40" CornerRadius="12"
                                Background="#2000FF94">
                            <TextBlock Text="&#x2713;" FontSize="18" Foreground="#00FF94" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Без абонемента -->
                <Border Grid.Column="2" Style="{StaticResource GlassCard}" Margin="0,0,12,0" Padding="20">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#15F59E0B" Offset="0"/>
                            <GradientStop Color="#08503010" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Без абонемента" Foreground="#60FFFFFF" FontFamily="Segoe UI" FontSize="12"/>
                            <TextBlock x:Name="StatNoMembership" Text="355" Foreground="#F59E0B" 
                                       FontFamily="Segoe UI" FontSize="48" FontWeight="Bold" Margin="0,8,0,0">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#F59E0B" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </StackPanel>
                        <Border HorizontalAlignment="Right" VerticalAlignment="Top" Width="40" Height="40" CornerRadius="12"
                                Background="#20F59E0B">
                            <TextBlock Text="&#x26A0;" FontSize="16" Foreground="#F59E0B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Нові цього місяця -->
                <Border Grid.Column="3" Style="{StaticResource GlassCard}" Padding="20">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#15C084FC" Offset="0"/>
                            <GradientStop Color="#08402060" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Нових за місяць" Foreground="#60FFFFFF" FontFamily="Segoe UI" FontSize="12"/>
                            <TextBlock x:Name="StatNewThisMonth" Text="+50" Foreground="#C084FC" 
                                       FontFamily="Segoe UI" FontSize="48" FontWeight="Bold" Margin="0,8,0,0">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#C084FC" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </StackPanel>
                        <Border HorizontalAlignment="Right" VerticalAlignment="Top" Width="40" Height="40" CornerRadius="12"
                                Background="#20C084FC">
                            <TextBlock Text="&#x2191;" FontSize="18" Foreground="#C084FC" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- ══════════════════════════════════════════════════════════════
                                         ПОШУК
                 ══════════════════════════════════════════════════════════════ -->
            <Border Grid.Row="2" Style="{StaticResource GlassCard}" Margin="0,0,0,20" Padding="20,16"
                    CornerRadius="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Іконка пошуку -->
                    <Border Width="40" Height="40" CornerRadius="12" Background="#10FFFFFF" VerticalAlignment="Center">
                        <TextBlock Text="&#x1F50D;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Поле пошуку -->
                    <TextBox Grid.Column="1" x:Name="SearchBox" Style="{StaticResource SearchTextBox}"
                             Margin="16,0" TextChanged="SearchBox_TextChanged"/>

                    <!-- Фільтр статусу -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Border x:Name="FilterActive" CornerRadius="10" Padding="14,8" Margin="0,0,8,0" Cursor="Hand"
            Background="#1500FF94" BorderThickness="1" BorderBrush="#3000FF94"
            MouseLeftButtonUp="FilterActive_Click">
                            <TextBlock x:Name="FilterActiveText" Text="Активні" Foreground="#00FF94" FontFamily="Segoe UI" FontSize="21" FontWeight="SemiBold"/>
                        </Border>
                        <Border x:Name="FilterNoMembership" CornerRadius="10" Padding="14,8" Margin="0,0,8,0" Cursor="Hand"
            Background="#10FFFFFF" BorderThickness="1" BorderBrush="#20FFFFFF"
            MouseLeftButtonUp="FilterNoMembership_Click">
                            <TextBlock x:Name="FilterNoMembershipText" Text="Без абонемента" Foreground="#70FFFFFF" FontFamily="Segoe UI" FontSize="21"/>
                        </Border>
                        <Border x:Name="FilterAll" CornerRadius="10" Padding="14,8" Cursor="Hand"
            Background="#10FFFFFF" BorderThickness="1" BorderBrush="#20FFFFFF"
            MouseLeftButtonUp="FilterAll_Click">
                            <TextBlock x:Name="FilterAllText" Text="Всі" Foreground="#70FFFFFF" FontFamily="Segoe UI" FontSize="21"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════════════════
                                     ТАБЛИЦЯ КЛІЄНТІВ
                 ══════════════════════════════════════════════════════════════ -->
            <Border Grid.Row="3" Style="{StaticResource GlassCard}" CornerRadius="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок таблиці -->
                    <Border Grid.Row="0" BorderBrush="#15FFFFFF" BorderThickness="0,0,0,1" Padding="24,18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="КЛІЄНТ" Foreground="#50FFFFFF" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="EMAIL" Foreground="#50FFFFFF" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="ТЕЛЕФОН" Foreground="#50FFFFFF" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="3" Text="СТАТУС" Foreground="#50FFFFFF" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="4" Text="ДІЇ" Foreground="#50FFFFFF" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Список клієнтів -->
                    <ListView x:Name="ClientsList" Grid.Row="1"
                              Background="Transparent" BorderThickness="0" Foreground="White"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem" BasedOn="{StaticResource TableRow}"/>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Ім'я + аватар -->
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Width="44" Height="44" CornerRadius="14" Margin="0,0,14,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#4A8AFF" Offset="0"/>
                                                    <GradientStop Color="#3A70D0" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Border.Effect>
                                                <DropShadowEffect Color="#4A8AFF" BlurRadius="15" ShadowDepth="0" Opacity="0.4"/>
                                            </Border.Effect>
                                            <TextBlock Text="{Binding Initials}"
                                                       Foreground="White" FontFamily="Segoe UI" FontSize="14" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Foreground="#FFFFFF" FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0} {1}">
                                                        <Binding Path="FirstName"/>
                                                        <Binding Path="LastName"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock Text="{Binding RegistrationDate, StringFormat='Клієнт з {0:dd.MM.yyyy}'}"
                                                       Foreground="#40FFFFFF" FontFamily="Segoe UI" FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Email -->
                                    <TextBlock Grid.Column="1" Text="{Binding Email}"
                                               Foreground="#80FFFFFF" FontFamily="Segoe UI" FontSize="13"
                                               VerticalAlignment="Center"/>

                                    <!-- Телефон -->
                                    <TextBlock Grid.Column="2" Text="{Binding Phone}"
                                               Foreground="#80FFFFFF" FontFamily="Segoe UI" FontSize="13"
                                               VerticalAlignment="Center"/>

                                    <!-- Статус абонементу -->
                                    <Border Grid.Column="3" CornerRadius="10" Padding="12,6" 
                                            VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#1500FF94"/>
                                                <Setter Property="BorderBrush" Value="#3000FF94"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasActiveMembership}" Value="False">
                                                        <Setter Property="Background" Value="#15EF4444"/>
                                                        <Setter Property="BorderBrush" Value="#30EF4444"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Активний"/>
                                                    <Setter Property="Foreground" Value="#00FF94"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasActiveMembership}" Value="False">
                                                            <Setter Property="Text" Value="Немає"/>
                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <!-- Дії -->
                                    <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Style="{StaticResource IconButton}" Margin="0,0,6,0"
                                                ToolTip="Переглянути" Tag="{Binding Id}" Click="ViewClient_Click">
                                            <TextBlock Text="&#x1F441;" FontSize="14"/>
                                        </Button>
                                        <Button Style="{StaticResource IconButton}" Margin="0,0,6,0"
                                                ToolTip="Редагувати" Tag="{Binding Id}" Click="EditClient_Click">
                                            <TextBlock Text="&#x270E;" FontSize="14" Foreground="#4A8AFF"/>
                                        </Button>
                                        <Button Style="{StaticResource IconButtonDanger}"
                                                ToolTip="Видалити" Tag="{Binding Id}" Click="DeleteClient_Click">
                                            <TextBlock Text="&#x1F5D1;" FontSize="14" Foreground="#EF4444"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Пуста таблиця -->
                    <StackPanel x:Name="EmptyState" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="Collapsed">
                        <Border Width="80" Height="80" CornerRadius="20" Margin="0,0,0,20">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#154A8AFF" Offset="0"/>
                                    <GradientStop Color="#084A8AFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="&#x1F465;" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Клієнтів не знайдено" Foreground="#FFFFFF" FontFamily="Segoe UI" FontSize="18" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Спробуйте змінити параметри пошуку" Foreground="#50FFFFFF" FontFamily="Segoe UI" FontSize="13"
                                   HorizontalAlignment="Center" Margin="0,8,0,20"/>
                        <Button Style="{StaticResource NeonButton}" HorizontalAlignment="Center" Click="AddClient_Click">
                            <TextBlock Text="+ Додати першого клієнта" Foreground="#0A1A10" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>