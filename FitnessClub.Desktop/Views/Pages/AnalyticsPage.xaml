                                                    <Border Width="36" Height="36" CornerRadius="18" Margin="0,0,12,0">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#00f5ff" Offset="0"/>
                                                                <GradientStop Color="#bf5af2" Offset="1"/>
