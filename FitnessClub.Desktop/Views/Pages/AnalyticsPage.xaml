                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,14,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <Border Width="4" Height="18" CornerRadius="2" Margin="0,0,12,0"
                                            Background="{StaticResource GradientPinkOrange}"/>
                                    <TextBlock Text="Скасування по місяцях"
                                               Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                                </StackPanel>
                                <oxy:PlotView x:Name="CnlTrendChart" Height="240" Background="Transparent"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource Card}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <Border Width="4" Height="18" CornerRadius="2" Margin="0,0,12,0"
                                            Background="{StaticResource GradientCyanPurple}"/>
                                    <TextBlock Text="Причини скасувань"
                                               Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                                </StackPanel>
                                <oxy:PlotView x:Name="CnlReasonsChart" Height="240" Background="Transparent"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Width="4" Height="18" CornerRadius="2" Margin="0,0,12,0"
                                        Background="{StaticResource GradientPinkOrange}"/>
                                <TextBlock Text="Деталізація скасувань" Foreground="White"
                                           FontSize="15" FontWeight="SemiBold"/>
                            </StackPanel>
                            <Border Background="#08ffffff" CornerRadius="10" Padding="16,12" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="110"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="ДАТА" Foreground="#5a6580" FontSize="10" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="1" Text="КЛІЄНТ / ТИП" Foreground="#5a6580" FontSize="10" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="2" Text="КАТЕГОРІЯ" Foreground="#5a6580" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="СТАТУС" Foreground="#5a6580" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="ВТРАТИ" Foreground="#5a6580" FontSize="10" FontWeight="Bold" HorizontalAlignment="Right"/>
                                </Grid>
                            </Border>
                            <ItemsControl x:Name="CnlDetailList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#10ffffff" BorderThickness="0,0,0,1" Padding="0,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="110"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding DateStr}" Foreground="#7a8090" FontSize="13" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ClientName}" Foreground="White" FontSize="14"/>
                                                    <TextBlock Text="{Binding TypeName}" Foreground="#5a6580" FontSize="11"/>
                                                </StackPanel>
                                                <Border Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        Background="{Binding CategoryBg}" CornerRadius="8" Padding="10,5">
                                                    <TextBlock Text="{Binding Category}" Foreground="{Binding CategoryFg}" FontSize="12"/>
                                                </Border>
                                                <Border Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        Background="#25ff453a" CornerRadius="8" Padding="10,5">
                                                    <TextBlock Text="Скасовано" Foreground="#ff453a" FontSize="12"/>
                                                </Border>
                                                <TextBlock Grid.Column="4" Text="{Binding LostAmount}"
                                                           Foreground="#ff453a" FontSize="14" FontWeight="SemiBold"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Grid>
</Page>
